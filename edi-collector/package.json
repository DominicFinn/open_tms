  },
  "dependencies": {
    "ssh2-sftp-client": "^11.0.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/ssh2-sftp-client": "^9.0.4",
    "@types/node-cron": "^3.0.11",
    "@types/node": "^20.11.0",
    "typescript": "^5.5.0",
    "tsx": "^4.7.0"
  }
}
