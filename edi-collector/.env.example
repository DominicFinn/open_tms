# Required: URL of the Open TMS backend API
BACKEND_URL=http://backend:3001

# Required: API key for authenticating with the backend
API_KEY=sk_live_your_api_key_here

# How often (in seconds) to refresh partner configs from the backend (default: 300)
POLL_CONFIG_INTERVAL=300

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
