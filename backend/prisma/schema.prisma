// ─── Warehouse App: Shipment Flags ──────────────────────────────────────────

model ShipmentFlag {
  id          String    @id @default(uuid())
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId  String
  flaggedBy   String    // User ID
  flaggedByName String  // User display name for quick lookup
  reason      String    // Free-text description of the issue
  resolved    Boolean   @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([shipmentId])
  @@index([resolved])
}

// ─── Warehouse App: WiFi Connectivity Log ───────────────────────────────────

model ConnectivityLog {
  id          String    @id @default(uuid())
  userId      String?
  deviceInfo  String?   // User agent / device model
  eventType   String    // "wifi_lost", "wifi_restored", "slow_connection"
  locationId  String?   // Which warehouse
  duration    Int?      // Seconds offline (for restored events)
  metadata    Json?     // Signal strength, SSID, etc.
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([locationId])
}

// ─── Agent Decision Logging (AI Compliance & Audit) ───────────────────────────
// Every AI agent decision is logged for compliance, auditability, and
// automation discovery. Captures what was decided, why, what context was
// available, what action was taken, and the outcome.

model AgentDecision {
  id                String    @id @default(uuid())
  organization      Organization @relation(fields: [orgId], references: [id])
  orgId             String

  // What agent made this decision
  agentType         String                            // triage, quality_analysis, route_optimization, carrier_selection

  // Which LLM produced this decision (for compliance - whose key, which model)
  modelProvider     String?                           // "anthropic", "openai", etc. - nullable for non-AI automations
  modelId           String?                           // "claude-sonnet-4-20250514", "gpt-4o", etc.

  // What triggered the agent
  triggerType       String                            // domain_event, schedule, manual, api
  triggerEventType  String?                           // e.g. "shipment.exception" - the domain event type that triggered this
  triggerEventId    String?                           // DomainEventLog.id of the triggering event

  // What entity this decision is about
  entityType        String?                           // "shipment", "order", "issue", etc.
  entityId          String?

  // The decision itself
  summary           String                            // Short human-readable summary: "Escalated issue to critical priority"
  reasoning         String                            // Full reasoning chain from the agent
  context           Json                              // Snapshot of data the agent had when deciding
  conversationLog   Json?                             // Raw LLM message exchange [{role, content}...] for audit/debugging
  confidence        Float?                            // 0.0 - 1.0, how confident the agent was

  // What action was taken
  actionType        String                            // create_issue, escalate_issue, change_priority, notify, no_action, etc.
  actionPayload     Json?                             // Details of the action taken (e.g. { issueId, newPriority })
  actionEntityType  String?                           // Entity created/modified by the action
  actionEntityId    String?                           // ID of entity created/modified

  // Outcome tracking (filled in later by human review or automated feedback)
  outcomeStatus     String    @default("pending")     // pending, correct, incorrect, partially_correct
  outcomeNotes      String?                           // Human reviewer's notes
  outcomeRecordedAt DateTime?
  outcomeRecordedBy String?                           // User who reviewed

  // Token usage tracking (for cost monitoring)
  inputTokens       Int?                              // Tokens sent to the LLM
  outputTokens      Int?                              // Tokens received from the LLM
  durationMs        Int?                              // Wall-clock time for the LLM call in milliseconds

  // Config traceability (which prompt produced this decision)
  agentConfigId     String?                           // AgentConfig.id
  promptVersionId   String?                           // AgentConfigVersion.id
  matchedConditions Json?                             // Conditions in unified format [{field,operator,value}...]

  // Automation promotion
  promotedToAutomation Boolean @default(false)
  promotedAt           DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([orgId])
  @@index([agentType])
  @@index([entityType, entityId])
  @@index([actionType])
  @@index([outcomeStatus])
  @@index([triggerEventType])
  @@index([createdAt])
  @@index([promotedToAutomation])
}

model AgentDecisionReadModel {
  id                   String    @id
  organization         Organization @relation(fields: [orgId], references: [id])
  orgId                String

  agentType            String
  modelProvider        String?
  modelId              String?
  triggerType          String
  triggerEventType     String?
  entityType           String?
  entityId             String?
  summary              String
  confidence           Float?
  actionType           String
  actionEntityType     String?
  actionEntityId       String?
  outcomeStatus        String    @default("pending")
  promotedToAutomation Boolean   @default(false)
  inputTokens          Int?
  outputTokens         Int?
  durationMs           Int?

  createdAt            DateTime
  updatedAt            DateTime

  @@index([orgId])
  @@index([agentType])
  @@index([actionType])
  @@index([outcomeStatus])
  @@index([createdAt])
}

// ─── Agent Configuration (configurable prompts & behaviour) ──────────────────

model AgentConfig {
  id                         String    @id @default(uuid())
  organization               Organization @relation(fields: [orgId], references: [id])
  orgId                      String

  agentType                  String                            // "triage" (extensible for future agents)
  name                       String                            // "Shipment Triage Agent"
  description                String?

  enabled                    Boolean   @default(true)

  // Which events trigger this agent (null = use code defaults)
  subscribedEvents           Json?                             // ["shipment.exception", "sla.breached", ...]

  // Active prompt version
  activeVersionId            String?

  // LLM tuning (null = use code defaults: temp 0.2, tokens 512)
  temperature                Float?
  maxTokens                  Int?

  // Behaviour tuning
  confidenceThreshold        Float?                            // 0-1, below this = override to no_action
  deduplicationWindowMinutes Int?                              // null = code default (30)

  versions                   AgentConfigVersion[]

  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@unique([orgId, agentType])
  @@index([orgId])
  @@index([agentType])
}

model AgentConfigVersion {
  id              String      @id @default(uuid())
  config          AgentConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  configId        String

  versionNumber   Int
  systemPrompt    String      @db.Text
  changeNote      String?

  createdAt       DateTime    @default(now())
  createdBy       String?

  @@unique([configId, versionNumber])
  @@index([configId])
}

// ─── Automation Rules (deterministic rules promoted from agent decisions) ─────

model AutomationRule {
  id                String    @id @default(uuid())
  organization      Organization @relation(fields: [orgId], references: [id])
  orgId             String

  name              String                            // "Critical delay auto-escalation"
  description       String?

  enabled           Boolean   @default(true)
  priority          Int       @default(50)            // 1-100, lower = evaluated first

  // Trigger: which events this rule listens to
  eventPattern      String                            // "shipment.exception", "sla.breached", "shipment.*"

  // Conditions: JSON array of {field, operator, value}
  conditions        Json                              // [{ field, operator, value }, ...]

  // Action
  actionType        String                            // "create_issue", "escalate_issue"
  actionConfig      Json                              // { issuePriority, issueCategory, issueTitle, ... }

  // Provenance: which agent decision was this promoted from?
  sourceDecisionId  String?                           // AgentDecision.id (null if manually created)

  // Skill chain support (for complex multi-step actions)
  skillChainId      String?                           // SkillChain.id (when actionType = "skill_chain")
  inlineSteps       Json?                             // Inline SkillChainStep[] for one-off chains

  // Stats
  executionCount    Int       @default(0)
  lastExecutedAt    DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  executions        AutomationExecutionLog[]

  @@index([orgId, enabled])
  @@index([eventPattern])
  @@index([priority])
}

model AutomationExecutionLog {
  id                String    @id @default(uuid())
  orgId             String

  rule              AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleId            String
  ruleName          String                            // Denormalized for audit

  // What triggered it
  eventType         String
  eventId           String                            // DomainEventLog.id
  entityType        String
  entityId          String

  // What it did
  actionType        String
  actionResult      Json?                             // { issueId, success, error }

  // Evaluation trace
  conditionsMatched Boolean
  evaluationMs      Int?

  createdAt         DateTime  @default(now())

  @@index([orgId])
  @@index([ruleId])
  @@index([createdAt])
}

// ─── Skills (extensible action system) ───────────────────────────────────────

model SkillConfig {
  id            String    @id @default(uuid())
  organization  Organization @relation(fields: [orgId], references: [id])
  orgId         String

  skillType     String                            // "send_email", "call_webhook", etc.
  name          String                            // "Ops Webhook" or "Company SMTP"
  config        Json                              // Skill-specific config (API keys, URLs, etc.)
  enabled       Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([orgId, skillType, name])
  @@index([orgId])
  @@index([skillType])
}

model SkillChain {
  id            String    @id @default(uuid())
  organization  Organization @relation(fields: [orgId], references: [id])
  orgId         String

  name          String                            // "Critical Delay Response"
  description   String?

  // Ordered array of SkillChainStep[] (skill nodes + question nodes)
  steps         Json                              // SkillChainStep[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orgId])
}

// ─── Financial: Quotes ──────────────────────────────────────────────────────

model Quote {
  id                  String    @id @default(uuid())
  orgId               String
  quoteNumber         String    @unique           // QTE-0001
  version             Int       @default(1)       // For revisions
  parentQuoteId       String?                     // Links revisions
  parentQuote         Quote?    @relation("QuoteRevisions", fields: [parentQuoteId], references: [id])
  revisions           Quote[]   @relation("QuoteRevisions")
  status              String    @default("draft") // draft, sent, accepted, declined, expired, superseded

  customer            Customer  @relation(fields: [customerId], references: [id])
  customerId          String

  // Route details (snapshot at time of quote)
  originId            String?
  destinationId       String?
  serviceLevel        String    @default("FTL")   // FTL, LTL
  equipmentType       String?

  // Financial
  totalRevenueCents   Int                         // What we charge customer
  totalCostCents      Int                         // Expected carrier cost
  marginCents         Int                         // revenue - cost
  marginPercent       Decimal   @db.Decimal(5,2)
  currency            String    @default("USD")

  // Validity
  validFrom           DateTime  @default(now())
  validUntil          DateTime                    // Expiration

  // Conversion
  orderId             String?                     // Set when quote is accepted and converted

  notes               String?
  createdBy           String?

  lineItems           QuoteLineItem[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orgId])
  @@index([customerId])
  @@index([status])
}

model QuoteLineItem {
  id                  String    @id @default(uuid())
  quote               Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId             String

  chargeType          String    // linehaul, fuel_surcharge, accessorial, discount
  description         String
  amountCents         Int       // Positive = charge, negative = discount
  currency            String    @default("USD")

  // For accessorials
  accessorialCode     String?

  // For LTL
  freightClass        String?
  weight              Decimal?  @db.Decimal(10,2)
  ratePerCwt          Int?      // Rate per hundredweight in cents

  quantity            Int       @default(1)

  createdAt           DateTime  @default(now())

  @@index([quoteId])
}

// ─── Financial: Charges ─────────────────────────────────────────────────────

model Charge {
  id                  String    @id @default(uuid())
  orgId               String

  // Polymorphic: a charge can be on an order, a shipment, or both
  order               Order?    @relation(fields: [orderId], references: [id])
  orderId             String?
  shipment            Shipment? @relation(fields: [shipmentId], references: [id])
  shipmentId          String?

  // Charge classification
  chargeType          String    // linehaul, fuel_surcharge, accessorial, discount, adjustment, claim_deduction
  chargeCategory      String    // revenue (what customer pays) | cost (what we pay carrier)
  description         String

  // Amount — always in integer cents to avoid floating-point errors
  amountCents         Int       // Positive = charge, negative = credit/discount
  currency            String    @default("USD")

  // Source of this charge
  source              String    @default("manual") // manual, contract_rate, quote, tender_bid, carrier_invoice, adjustment
  sourceId            String?                      // ID of quote, tender bid, carrier invoice line, etc.

  // For accessorials
  accessorialCode     String?

  // LTL-specific
  freightClass        String?
  nmfcCode            String?
  ratedWeight         Decimal?  @db.Decimal(10,2)  // Actual rated weight (may differ from declared)
  ratePerCwt          Int?                         // Rate per hundredweight in cents

  // Lifecycle
  status              String    @default("pending") // pending, approved, invoiced, disputed, written_off
  approvedBy          String?
  approvedAt          DateTime?

  createdBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orgId])
  @@index([orderId])
  @@index([shipmentId])
  @@index([chargeCategory])
  @@index([status])
}

// ─── Financial: Shipment Financial Summary ──────────────────────────────────

model ShipmentFinancialSummary {
  id                       String   @id @default(uuid())
  orgId                    String

  shipment                 Shipment @relation(fields: [shipmentId], references: [id])
  shipmentId               String   @unique

  // Expected (from quote/contract/tender)
  expectedRevenueCents     Int      @default(0)
  expectedCostCents        Int      @default(0)
  expectedMarginCents      Int      @default(0)

  // Actual (from charges posted)
  actualRevenueCents       Int      @default(0)
  actualCostCents          Int      @default(0)
  actualMarginCents        Int      @default(0)

  currency                 String   @default("USD")

  // Billing readiness
  billingStatus            String   @default("not_ready") // not_ready, ready_to_invoice, invoiced, paid
  podReceived              Boolean  @default(false)

  // Carrier payment status
  carrierPaymentStatus     String   @default("not_ready") // not_ready, invoice_received, approved, paid

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([orgId])
  @@index([billingStatus])
  @@index([carrierPaymentStatus])
}

// ─── Financial: Customer Invoices (Accounts Receivable) ─────────────────────

model Invoice {
  id                  String    @id @default(uuid())
  orgId               String
  invoiceNumber       String    @unique           // INV-20260401-0001

  customer            Customer  @relation(fields: [customerId], references: [id])
  customerId          String

  // Status
  status              String    @default("draft") // draft, approved, sent, partial_paid, paid, overdue, void, disputed

  // Financial totals (computed from line items)
  subtotalCents       Int
  taxCents            Int       @default(0)
  totalCents          Int
  paidCents           Int       @default(0)
  balanceCents        Int                         // total - paid
  currency            String    @default("USD")

  // Terms
  paymentTermsDays    Int       @default(30)
  issueDate           DateTime  @default(now())
  dueDate             DateTime

  // Dates
  sentAt              DateTime?
  paidAt              DateTime?

  // Reminders
  lastReminderSentAt  DateTime?
  reminderCount       Int       @default(0)

  notes               String?
  internalNotes       String?
  createdBy           String?

  lineItems           InvoiceLineItem[]
  payments            Payment[]
  creditNotes         CreditNote[]  @relation("InvoiceCreditNotes")

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orgId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceLineItem {
  id                  String    @id @default(uuid())
  invoice             Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId           String

  // Link to source
  shipmentId          String?
  orderId             String?
  chargeId            String?   // Links back to the Charge record

  // Line item details
  chargeType          String    // linehaul, fuel_surcharge, accessorial, discount
  description         String
  quantity            Int       @default(1)
  unitPriceCents      Int
  totalCents          Int
  currency            String    @default("USD")

  // LTL-specific
  freightClass        String?
  weight              Decimal?  @db.Decimal(10,2)

  createdAt           DateTime  @default(now())

  @@index([invoiceId])
  @@index([shipmentId])
}

// ─── Financial: Payments (Customer) ─────────────────────────────────────────

model Payment {
  id                  String    @id @default(uuid())
  orgId               String

  invoice             Invoice   @relation(fields: [invoiceId], references: [id])
  invoiceId           String

  amountCents         Int
  currency            String    @default("USD")

  paymentMethod       String?   // check, ach, wire, credit_card
  referenceNumber     String?   // Check number, transaction ID

  receivedDate        DateTime  @default(now())
  recordedBy          String?

  notes               String?

  createdAt           DateTime  @default(now())

  @@index([orgId])
  @@index([invoiceId])
}

// ─── Financial: Carrier Invoices (Accounts Payable) ─────────────────────────

model CarrierInvoice {
  id                  String    @id @default(uuid())
  orgId               String
  invoiceNumber       String                      // Carrier's invoice number

  carrier             Carrier   @relation(fields: [carrierId], references: [id])
  carrierId           String

  // Status
  status              String    @default("received") // received, matched, discrepancy, approved, scheduled, paid, disputed

  // Financial totals
  totalCents          Int
  approvedCents       Int?      // May differ from totalCents after audit
  paidCents           Int       @default(0)
  currency            String    @default("USD")

  // Terms
  paymentTermsDays    Int       @default(30)
  receivedDate        DateTime  @default(now())
  dueDate             DateTime

  // Three-way match
  matchStatus         String    @default("pending") // pending, matched, partial_match, mismatch
  varianceCents       Int?      // Difference between expected and invoiced
  variancePercent     Decimal?  @db.Decimal(5,2)
  autoApproved        Boolean   @default(false)

  // EDI 210
  edi210Content       String?   // Raw EDI 210 content
  ediTransactionLogId String?   // Link to EdiTransactionLog

  // Approval
  approvedBy          String?
  approvedAt          DateTime?

  // Payment
  scheduledPayDate    DateTime?
  paidAt              DateTime?
  paymentReference    String?   // Check number, ACH reference, etc.

  notes               String?

  // Quick Pay / Factoring (broker feature)
  quickPayRequested     Boolean   @default(false)
  quickPayDiscountPct   Decimal?  @db.Decimal(5,2)  // e.g., 2.00 = 2% discount for quick pay
  quickPayDiscountCents Int?                         // Computed: totalCents * discountPct / 100
  quickPayDueDate       DateTime?                    // Accelerated payment date

  lineItems           CarrierInvoiceLineItem[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([orgId, carrierId, invoiceNumber])
  @@index([orgId])
  @@index([carrierId])
  @@index([status])
  @@index([dueDate])
  @@index([matchStatus])
}

model CarrierInvoiceLineItem {
  id                  String    @id @default(uuid())
  carrierInvoice      CarrierInvoice @relation(fields: [carrierInvoiceId], references: [id], onDelete: Cascade)
  carrierInvoiceId    String

  shipmentId          String?
  chargeId            String?

  chargeType          String    // linehaul, fuel_surcharge, accessorial, detention, reweigh_adjustment
  description         String
  amountCents         Int
  currency            String    @default("USD")

  // Match result against expected
  expectedAmountCents Int?
  varianceCents       Int?
  matchStatus         String    @default("pending") // pending, matched, variance, unmatched

  // LTL-specific
  freightClass        String?
  billedWeight        Decimal?  @db.Decimal(10,2)
  actualWeight        Decimal?  @db.Decimal(10,2)   // From re-weigh

  createdAt           DateTime  @default(now())

  @@index([carrierInvoiceId])
  @@index([shipmentId])
}

// ─── Financial: Queries & Disputes ──────────────────────────────────────────

model FinancialQuery {
  id                  String    @id @default(uuid())
  orgId               String
  queryNumber         String    @unique           // QRY-0001

  // Source: customer or carrier
  queryType           String    // customer_dispute, carrier_dispute

  // Related entities
  invoiceId           String?
  carrierInvoiceId    String?
  shipmentId          String?

  // Query details
  reason              String    // overcharge, service_failure, missing_pod, wrong_rate, damage_claim, missing_items, temperature_excursion
  description         String
  disputedAmountCents Int?

  // Lifecycle
  status              String    @default("raised") // raised, investigating, resolved_adjusted, resolved_upheld, closed

  // Resolution
  resolvedBy          String?
  resolvedAt          DateTime?
  resolutionNotes     String?
  adjustmentCents     Int?      // Positive = credit to querying party

  // Link to credit/debit note if adjustment made
  creditNoteId        String?

  // Link to cargo discrepancy or excursion if applicable
  cargoDiscrepancyId  String?
  coldChainExcursionId String?

  assigneeId          String?

  createdBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orgId])
  @@index([status])
  @@index([queryType])
  @@index([invoiceId])
  @@index([carrierInvoiceId])
}

// ─── Financial: Credit & Debit Notes ────────────────────────────────────────

model CreditNote {
  id                  String    @id @default(uuid())
  orgId               String
  creditNoteNumber    String    @unique           // CN-0001

  noteType            String    // credit, debit

  invoice             Invoice?  @relation("InvoiceCreditNotes", fields: [invoiceId], references: [id])
  invoiceId           String?

  customer            Customer? @relation("CustomerCreditNotes", fields: [customerId], references: [id])
  customerId          String?
  carrier             Carrier?  @relation("CarrierCreditNotes", fields: [carrierId], references: [id])
  carrierId           String?

  amountCents         Int
  currency            String    @default("USD")

  reason              String
  description         String

  // Source
  queryId             String?   // From a resolved FinancialQuery

  // Lifecycle
  status              String    @default("draft") // draft, approved, applied
  approvedBy          String?
  approvedAt          DateTime?
  appliedAt           DateTime?

  createdBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orgId])
  @@index([invoiceId])
  @@index([customerId])
  @@index([carrierId])
}

// ─── Brokerage: Commission Tracking ────────────────────────────────────────

model Commission {
  id                  String    @id @default(uuid())
  orgId               String

  user                User      @relation(fields: [userId], references: [id])
  userId              String                                // The broker agent / sales rep
  shipment            Shipment  @relation(fields: [shipmentId], references: [id])
  shipmentId          String

  // Calculation
  basisType           String    @default("margin")          // "margin" | "revenue"
  basisAmountCents    Int                                   // The amount the commission is calculated on
  commissionPercent   Decimal   @db.Decimal(5,2)            // e.g., 10.00 = 10%
  commissionCents     Int                                   // Computed: basisAmountCents * percent / 100
  currency            String    @default("USD")

  // Lifecycle
  status              String    @default("accrued")         // accrued | approved | paid
  approvedBy          String?
  approvedAt          DateTime?
  paidAt              DateTime?
  paymentReference    String?

  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orgId])
  @@index([userId])
  @@index([shipmentId])
  @@index([status])
}

// ─── Financial: Invoice Read Model ──────────────────────────────────────────

model InvoiceReadModel {
  id                  String    @id
  orgId               String
  invoiceNumber       String    @unique
  customerId          String
  customerName        String
  status              String
  totalCents          Int
  paidCents           Int
  balanceCents        Int
  currency            String
  issueDate           DateTime
  dueDate             DateTime
  daysPastDue         Int       @default(0)
  shipmentCount       Int       @default(0)
  lineItemCount       Int       @default(0)
  createdAt           DateTime
  updatedAt           DateTime

  @@index([orgId])
  @@index([status])
  @@index([customerId])
  @@index([dueDate])
  @@index([daysPastDue])
}

// ─── Comments (polymorphic, any entity) ─────────────────────────────────────

model Comment {
  id            String   @id @default(uuid())
  orgId         String
  entityType    String                                // "issue", "shipment", "order", "trackable_unit"
  entityId      String
  authorId      String?                               // User.id or null for system/agent
  authorName    String
  authorType    String   @default("user")             // "user", "agent", "system"
  body          String                                // Markdown text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Issue Labels ───────────────────────────────────────────────────────────

model IssueLabel {
  id          String   @id @default(uuid())
  orgId       String
  name        String                                  // e.g. "cold-chain", "hazmat", "vip-customer"
  color       String   @default("#6B7280")            // Hex color for chip display
  assignments IssueLabelAssignment[]
  createdAt   DateTime @default(now())

  @@unique([orgId, name])
  @@index([orgId])
}

model IssueLabelAssignment {
  id       String     @id @default(uuid())
  issueId  String
  labelId  String
  issue    Issue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label    IssueLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([issueId, labelId])
  @@index([issueId])
  @@index([labelId])
}

// ─── Kanban Views (shared org-wide) ─────────────────────────────────────────

model KanbanView {
  id          String   @id @default(uuid())
  orgId       String
  name        String                                  // "Cold Chain Issues", "Customer X Board"
  description String?
  filters     Json                                    // { priority?, category?, sourceEntityType?, customerId?, labels?, slaStatus?, assigneeId? }
  groupBy     String   @default("status")             // "status", "priority", "category", "assignee"
  sortBy      String   @default("createdAt")          // "createdAt", "priority", "slaStatus"
  isDefault   Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
}

// ===========================================
// Carrier Tracking API Integrations
// ===========================================

model CarrierTrackingIntegration {
  id                    String    @id @default(uuid())
  carrier               Carrier   @relation(fields: [carrierId], references: [id])
  carrierId             String    @unique

  // Provider config
  providerType          String    // fedex, ups, dhl, usps, easypost, aftership, edi_214, manual
  status                String    @default("pending_setup") // pending_setup, active, error, disabled
  credentials           Json?     // Encrypted: OAuth client ID/secret, API keys, account numbers

  // Webhook config (push from carrier)
  webhookEnabled        Boolean   @default(false)
  webhookSecret         String?   // Shared secret for signature verification
  webhookEndpointId     String?   // ID of registered webhook at carrier API

  // Polling config (pull from carrier)
  pollingEnabled        Boolean   @default(false)
  pollingIntervalSeconds Int      @default(900) // 15 min default
  lastPolledAt          DateTime?

  // Rate limiting
  rateLimitDailyMax     Int?      // Provider-specific daily limit
  rateLimitCallsToday   Int       @default(0)
  rateLimitResetAt      DateTime?

  // Error tracking
  lastErrorMessage      String?
  lastErrorAt           DateTime?

  // Metadata
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  trackingEvents        CarrierTrackingEvent[]

  @@index([providerType])
  @@index([status])
}

model CarrierTrackingEvent {
  id                String    @id @default(uuid())

  // Relations
  shipment          Shipment  @relation(fields: [shipmentId], references: [id])
  shipmentId        String
  carrier           Carrier   @relation(fields: [carrierId], references: [id])
  carrierId         String
  integration       CarrierTrackingIntegration @relation(fields: [integrationId], references: [id])
  integrationId     String

  // Tracking data
  providerType      String    // Denormalized for fast queries
  trackingNumber    String
  status            String    // Normalized: info_received, in_transit, out_for_delivery, delivered, exception, return_to_sender, unknown
  statusDetail      String?   // Provider's original status text
  statusCode        String?   // Provider's raw status code

  // Location
  city              String?
  state             String?
  country           String?
  postalCode        String?
  lat               Float?
  lng               Float?

  // Timing
  occurredAt        DateTime  // When the event actually happened at the carrier
  estimatedDelivery DateTime? // Carrier's predicted delivery

  // Delivery
  signedBy          String?   // Delivery signature name

  // Audit
  rawPayload        Json?     // Full provider response for debugging
  source            String    // webhook, poll, manual

  createdAt         DateTime  @default(now())

  @@index([shipmentId])
  @@index([carrierId])
  @@index([integrationId])
  @@index([trackingNumber])
  @@index([occurredAt])
  @@index([status])
}

// ─── Lane Route (Planned Route Polyline) ──────────────────────────────────────

model LaneRoute {
  id              String   @id @default(uuid())
  lane            Lane     @relation(fields: [laneId], references: [id], onDelete: Cascade)
  laneId          String   @unique // One route per lane
  orgId           String

  // The planned route geometry - Google-encoded polyline string
  encodedPolyline String   @db.Text

  // Decoded waypoints snapshot (JSON array of {lat, lng}) for quick access
  waypoints       Json     // [{lat: number, lng: number}, ...]

  // Route metadata from Google Maps Directions API
  distanceMeters  Int
  durationSeconds Int
  summary         String?  // Google's route summary (e.g., "via I-95 N")

  // Corridor config for deviation detection
  corridorMeters  Int      @default(5000) // How far off-route before alerting

  // Source tracking
  provider        String   @default("google") // "google" | "manual"
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orgId])
}

// ─── Quality Centre ────────────────────────────────────────────────────────────
// Read models and support tables for the Quality Centre dashboard.
// Provides aggregated quality metrics by carrier, lane, location, and customer.

model QualityIssueSummary {
  id                String    @id @default(uuid())
  orgId             String

  // Dimension - which entity this row aggregates for
  dimensionType     String                          // "carrier", "lane", "location", "customer"
  dimensionId       String                          // ID of the carrier/lane/location/customer
  dimensionName     String                          // Cached display name

  // Counts by category
  totalIssues       Int       @default(0)
  exceptionCount    Int       @default(0)
  delayCount        Int       @default(0)
  damageCount       Int       @default(0)
  complianceCount   Int       @default(0)
  otherCount        Int       @default(0)

  // Counts by priority
  criticalCount     Int       @default(0)
  highCount         Int       @default(0)
  mediumCount       Int       @default(0)
  lowCount          Int       @default(0)

  // Counts by status
  openCount         Int       @default(0)
  inProgressCount   Int       @default(0)
  resolvedCount     Int       @default(0)
  closedCount       Int       @default(0)

  // Quality indicators
  capaCount         Int       @default(0)           // Issues flagged needsCapa
  avgResolutionHours Float?                         // Average time to resolve (hours)
  lastIssueAt      DateTime?                        // When the most recent issue was created

  // Period tracking - rolling window
  periodStart       DateTime?                       // Start of the aggregation window (null = all-time)
  periodEnd         DateTime?                       // End of the aggregation window

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([orgId, dimensionType, dimensionId])
  @@index([orgId, dimensionType])
  @@index([orgId, totalIssues])
  @@index([lastIssueAt])
}

// ─── CAPA Follow-Up Notes ──────────────────────────────────────────────────────
// Contact-management-style follow-up system for CAPA reports.
// Supports 30/60/90 day reviews and ad-hoc notes.

model CAPAFollowUp {
  id              String    @id @default(uuid())
  orgId           String
  capaReportId    String
  capaReport      CAPAReport @relation(fields: [capaReportId], references: [id], onDelete: Cascade)

  // Follow-up details
  followUpType    String                          // "30_day", "60_day", "90_day", "ad_hoc", "effectiveness_check"
  dueDate         DateTime
  completedAt     DateTime?
  status          String    @default("pending")   // pending, completed, overdue, skipped

  // Content
  notes           String?
  outcome         String?                         // "on_track", "needs_attention", "escalated", "closed_effective", "closed_ineffective"
  actionItems     String?                         // Free-text follow-up actions

  // Who
  assigneeId      String?
  assigneeName    String?
  completedById   String?
  completedByName String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?

  @@index([orgId])
  @@index([capaReportId])
  @@index([dueDate])
  @@index([status])
}

// ─── SOP / GDP Audit Checklists ────────────────────────────────────────────────
// Standard Operating Procedure reviews and GDP compliance audit checklists.

model SOPChecklist {
  id              String    @id @default(uuid())
  orgId           String

  // Identification
  title           String                          // "GDP Annual Review", "Cold Chain SOP Check"
  description     String?
  sopReference    String?                         // e.g. "SOP-CC-001", "GDP-2024-v2"
  category        String                          // "gdp", "cold_chain", "warehouse", "transport", "general"
  frequency       String    @default("annual")    // "monthly", "quarterly", "annual", "one_off"

  // Status
  status          String    @default("draft")     // draft, active, archived
  version         Int       @default(1)

  // Schedule
  nextDueDate     DateTime?
  lastCompletedAt DateTime?
  lastCompletedBy String?

  items           SOPChecklistItem[]
  audits          SOPAudit[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?

  @@index([orgId])
  @@index([category])
  @@index([status])
  @@index([nextDueDate])
}

model SOPChecklistItem {
  id              String    @id @default(uuid())
  checklistId     String
  checklist       SOPChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  // Item definition
  sortOrder       Int       @default(0)
  section         String?                         // Group heading: "Documentation", "Storage", "Transport"
  question        String                          // "Are temperature records maintained for all cold chain shipments?"
  guidance        String?                         // Help text for the auditor
  evidenceRequired Boolean  @default(false)       // Does the auditor need to upload evidence?
  isCritical      Boolean   @default(false)       // Critical items fail the whole audit if not met

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  responses       SOPAuditResponse[]

  @@index([checklistId])
}

// An instance of completing a checklist (an "audit")
model SOPAudit {
  id              String    @id @default(uuid())
  orgId           String
  checklistId     String
  checklist       SOPChecklist @relation(fields: [checklistId], references: [id])

  // Audit metadata
  auditNumber     String                          // Auto-generated: AUDIT-YYYYMMDD-NNN
  status          String    @default("in_progress") // in_progress, completed, failed
  auditorId       String?
  auditorName     String?
  auditDate       DateTime  @default(now())

  // Results
  score           Float?                          // Percentage of items passed (0-100)
  passCount       Int       @default(0)
  failCount       Int       @default(0)
  naCount         Int       @default(0)
  findings        String?                         // Overall findings / summary
  correctiveActions String?                       // Actions required from this audit

  // Completion
  completedAt     DateTime?
  reviewedById    String?
  reviewedByName  String?
  reviewedAt      DateTime?

  responses       SOPAuditResponse[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orgId])
  @@index([checklistId])
  @@index([status])
  @@index([auditDate])
}

model SOPAuditResponse {
  id              String    @id @default(uuid())
  auditId         String
  audit           SOPAudit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
  checklistItemId String
  checklistItem   SOPChecklistItem @relation(fields: [checklistItemId], references: [id])

  // Response
  result          String                          // "pass", "fail", "na", "observation"
  notes           String?
  evidenceRef     String?                         // Storage key for uploaded evidence file
  correctiveAction String?                        // Item-level corrective action needed

  respondedAt     DateTime  @default(now())
  respondedById   String?
  respondedByName String?

  @@index([auditId])
  @@index([checklistItemId])
}

// ═══════════════════════════════════════════════════════════════
// WMS (Warehouse Management System) Models
// ═══════════════════════════════════════════════════════════════

model WarehouseZone {
  id              String   @id @default(uuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  name            String                       // e.g. "Bulk A", "Dock 3", "Cold Store"
  zoneType        String                       // receiving, bulk_storage, pick_face, staging, packing, shipping_dock, quarantine, returns, cross_dock
  temperatureZone String?                      // ambient, refrigerated, frozen
  hazmatCertified Boolean  @default(false)
  maxWeightKg     Float?
  maxVolumeCbm    Float?
  sortOrder       Int      @default(0)         // display/walk order
  active          Boolean  @default(true)

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  aisles          WarehouseAisle[]
  bins            WarehouseBin[]
  indoorAnchors   IndoorZoneAnchor[]
  unitsInZone     TrackableUnit[]  @relation("UnitCurrentZone")
  pickTasks       PickTask[]

  @@index([locationId])
  @@index([orgId])
  @@index([zoneType])
}

model WarehouseAisle {
  id          String   @id @default(uuid())
  zoneId      String
  zone        WarehouseZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  name        String                           // e.g. "A", "B"
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  bins        WarehouseBin[]

  @@index([zoneId])
  @@index([locationId])
}

model WarehouseBin {
  id                  String   @id @default(uuid())
  zoneId              String
  zone                WarehouseZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  aisleId             String?
  aisle               WarehouseAisle? @relation(fields: [aisleId], references: [id])
  locationId          String
  location            Location @relation(fields: [locationId], references: [id])
  label               String                   // unique within location, e.g. "BULK-A-01-03-B"
  binType             String                   // pallet, shelf, floor, dock_door, staging, pack_station
  maxWeightKg         Float?
  maxVolumeCbm        Float?
  maxPalletPositions  Int?
  temperatureZone     String?                  // inherits from zone if null
  hazmatCertified     Boolean  @default(false) // inherits from zone if not set
  level               Int?                     // vertical position (lower = easier to reach)
  walkSequence        Int      @default(0)     // monotonically increasing along natural walk path
  active              Boolean  @default(true)

  // Denormalized running totals
  currentWeightKg     Float    @default(0)
  currentVolumeCbm    Float    @default(0)
  currentPalletCount  Int      @default(0)

  orgId               String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  unitsInBin          TrackableUnit[]  @relation("UnitCurrentBin")
  inventoryRecords    InventoryRecord[]
  putawayTasksAsSource  PutawayTask[]  @relation("PutawaySource")
  putawayTasksAsTarget  PutawayTask[]  @relation("PutawayTarget")
  pickLines           PickLine[]
  packTasksAtStation  PackTask[]       @relation("PackStation")
  stagingAssignments  StagingAssignment[]
  receivingAppointmentsDock ReceivingAppointment[] @relation("AppointmentDock")
  receivingTasksDock  ReceivingTask[]  @relation("ReceivingDock")

  @@unique([locationId, label])
  @@index([zoneId])
  @@index([locationId])
  @@index([orgId])
  @@index([binType])
  @@index([walkSequence])
}

model IndoorZoneAnchor {
  id              String   @id @default(uuid())
  zoneId          String
  zone            WarehouseZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  anchorType      String                       // ble, wifi, uwb
  bleUuid         String?
  bleMajor        Int?
  bleMinor        Int?
  bleRssiThreshold Int?                        // proximity threshold (e.g. -70 dBm)
  wifiSsid        String?
  wifiBssid       String?
  uwbAnchorId     String?
  name            String?                      // friendly name, e.g. "Dock 3 Reader"
  lat             Float?                       // indoor coordinate (optional, for map rendering)
  lng             Float?
  active          Boolean  @default(true)

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([zoneId])
  @@index([orgId])
}

model ProductUom {
  id              String   @id @default(uuid())
  sku             String
  uomCode         String                       // EA, INNER, CASE, PALLET, or custom
  parentUomCode   String?                      // which UOM this rolls up into
  conversionFactor Int     @default(1)          // how many children fit in one of this
  lengthMm        Int?
  widthMm         Int?
  heightMm        Int?
  weightGrams     Int?
  barcodeGtin     String?                      // GTIN/UPC/EAN for scanning at this UOM
  isDefault       Boolean  @default(false)

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orgId, sku, uomCode])
  @@index([orgId])
  @@index([sku])
  @@index([barcodeGtin])
}

model InventoryRecord {
  id                  String   @id @default(uuid())
  locationId          String
  location            Location @relation(fields: [locationId], references: [id])
  binId               String
  bin                 WarehouseBin @relation(fields: [binId], references: [id])
  sku                 String
  uomCode             String   @default("EA")
  quantityOnHand      Int      @default(0)
  quantityAllocated   Int      @default(0)
  quantityAvailable   Int      @default(0)     // onHand - allocated
  quantityOnHold      Int      @default(0)
  ownerCustomerId     String?
  ownerCustomer       Customer? @relation("InventoryOwner", fields: [ownerCustomerId], references: [id])
  lotNumber           String?
  expiryDate          DateTime?
  lastCountedAt       DateTime?

  orgId               String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  transactions        InventoryTransaction[]
  allocations         Allocation[]
  pickLines           PickLine[]

  @@unique([binId, sku, uomCode, lotNumber, ownerCustomerId])
  @@index([locationId])
  @@index([orgId])
  @@index([sku])
  @@index([ownerCustomerId])
}

model InventoryTransaction {
  id                  String   @id @default(uuid())
  inventoryRecordId   String
  inventoryRecord     InventoryRecord @relation(fields: [inventoryRecordId], references: [id])
  transactionType     String                   // receive, putaway, pick, adjust, transfer, cycle_count, replenish, uom_converted
  quantityChange      Int                      // positive for in, negative for out
  previousQuantity    Int
  newQuantity         Int
  referenceType       String?                  // receiving_task, pick_task, adjustment, cycle_count
  referenceId         String?
  reasonCode          String?                  // damage, expired, recount, return, scrap, found
  performedBy         String?
  trackableUnitId     String?
  trackableUnit       TrackableUnit? @relation(fields: [trackableUnitId], references: [id])

  orgId               String

  createdAt           DateTime @default(now())

  @@index([inventoryRecordId])
  @@index([orgId])
  @@index([transactionType])
  @@index([createdAt])
}

model Allocation {
  id                  String   @id @default(uuid())
  orderLineItemId     String
  orderLineItem       OrderLineItem @relation(fields: [orderLineItemId], references: [id])
  inventoryRecordId   String
  inventoryRecord     InventoryRecord @relation(fields: [inventoryRecordId], references: [id])
  trackableUnitId     String?
  trackableUnit       TrackableUnit? @relation(fields: [trackableUnitId], references: [id])
  quantity            Int
  uomCode             String   @default("EA")
  state               String   @default("soft")  // soft, hard, picked, released
  lotNumber           String?
  allocatedAt         DateTime @default(now())
  expiresAt           DateTime?                    // soft allocations auto-expire

  orgId               String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([orderLineItemId])
  @@index([inventoryRecordId])
  @@index([orgId])
  @@index([state])
}

// ── Receiving ────────────────────────────────────────────────

model ReceivingAppointment {
  id                  String   @id @default(uuid())
  locationId          String
  location            Location @relation(fields: [locationId], references: [id])
  inboundShipmentId   String?
  dockBinId           String?
  dockBin             WarehouseBin? @relation("AppointmentDock", fields: [dockBinId], references: [id])
  scheduledAt         DateTime
  scheduledEndAt      DateTime
  status              String   @default("scheduled") // scheduled, checked_in, receiving, completed, no_show, cancelled
  carrierName         String?
  trailerNumber       String?
  sealNumber          String?
  asnReference        String?

  orgId               String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  receivingTasks      ReceivingTask[]

  @@index([locationId])
  @@index([orgId])
  @@index([scheduledAt])
  @@index([status])
}

model ReceivingTask {
  id                  String   @id @default(uuid())
  locationId          String
  location            Location @relation(fields: [locationId], references: [id])
  appointmentId       String?
  appointment         ReceivingAppointment? @relation(fields: [appointmentId], references: [id])
  inboundShipmentId   String?
  dockBinId           String?
  dockBin             WarehouseBin? @relation("ReceivingDock", fields: [dockBinId], references: [id])
  status              String   @default("pending") // pending, in_progress, inspection, completed, cancelled
  receivingType       String                       // asn, blind
  crossDock           Boolean  @default(false)
  assignedToUserId    String?

  orgId               String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  lines               ReceivingLine[]
  putawayTasks        PutawayTask[]

  @@index([locationId])
  @@index([orgId])
  @@index([status])
}

model ReceivingLine {
  id                  String   @id @default(uuid())
  receivingTaskId     String
  receivingTask       ReceivingTask @relation(fields: [receivingTaskId], references: [id], onDelete: Cascade)
  orderLineItemId     String?
  trackableUnitId     String?
  trackableUnit       TrackableUnit? @relation(fields: [trackableUnitId], references: [id])
  sku                 String
  uomCode             String   @default("EA")
  expectedQuantity    Int?
  receivedQuantity    Int      @default(0)
  damagedQuantity     Int      @default(0)
  inspectionStatus    String   @default("pending") // pending, pass, fail, quarantine
  lotNumber           String?
  expiryDate          DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([receivingTaskId])
}

// ── Putaway ──────────────────────────────────────────────────

model PutawayRule {
  id                    String   @id @default(uuid())
  locationId            String
  location              Location @relation(fields: [locationId], references: [id])
  name                  String
  priority              Int      @default(50)        // lower = higher priority
  active                Boolean  @default(true)

  // Criteria (all nullable = match any)
  skuPattern            String?                      // glob pattern, e.g. "PHARMA-*"
  temperatureRequirement String?                     // refrigerated, frozen
  hazmat                Boolean?
  customerId            String?
  velocityClass         String?                      // A, B, C
  unitType              String?                      // pallet, tote, box
  crossDockSortBy       String?                      // destination, carrier, route

  // Action
  targetType            String                       // zone, specific_bin, next_available_in_zone
  targetZoneId          String?
  targetBinId           String?
  preferLevel           String?                      // low, medium, high

  orgId                 String

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([locationId])
  @@index([orgId])
  @@index([priority])
}

model PutawayTask {
  id                  String   @id @default(uuid())
  locationId          String
  location            Location @relation(fields: [locationId], references: [id])
  receivingTaskId     String?
  receivingTask       ReceivingTask? @relation(fields: [receivingTaskId], references: [id])
  trackableUnitId     String
  trackableUnit       TrackableUnit @relation(fields: [trackableUnitId], references: [id])
  sourceBinId         String?
  sourceBin           WarehouseBin? @relation("PutawaySource", fields: [sourceBinId], references: [id])
  targetBinId         String
  targetBin           WarehouseBin  @relation("PutawayTarget", fields: [targetBinId], references: [id])
  status              String   @default("pending") // pending, assigned, in_progress, completed, cancelled
  putawayType         String                       // directed, manual, replenishment
  assignedToUserId    String?

  orgId               String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([locationId])
  @@index([orgId])
  @@index([status])
  @@index([trackableUnitId])
}

// ── Waves & Picking ──────────────────────────────────────────

model WaveTemplate {
  id              String   @id @default(uuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  name            String
  groupingRules   Json?                          // { customer, carrier, serviceLevel, shipFrom, shipCompleteOnly }
  cutoffTime      String?                        // HH:MM local
  pickStrategy    String   @default("discrete")  // discrete, batch, zone
  zonePickMode    String?                        // sequential (pick-and-pass) or parallel (pick-and-merge). Only used when pickStrategy=zone.
  minOrders       Int?
  maxOrders       Int?
  maxLabourHours  Float?
  priority        Int      @default(50)
  releaseSchedule String?                        // cron expression for auto-release
  autoRelease     Boolean  @default(false)
  active          Boolean  @default(true)

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  waves           Wave[]

  @@index([locationId])
  @@index([orgId])
}

model Wave {
  id              String   @id @default(uuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  templateId      String?
  template        WaveTemplate? @relation(fields: [templateId], references: [id])
  waveNumber      String                         // auto-generated, e.g. "W-2026-04-14-001"
  status          String   @default("planning")  // planning, released, in_progress, completed, cancelled
  pickStrategy    String   @default("discrete")
  zonePickMode    String?                        // sequential or parallel
  groupingCriteria Json?
  orderCount      Int      @default(0)
  lineCount       Int      @default(0)
  projectedCompletionAt DateTime?
  cutoffAt        DateTime?

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  waveOrders      WaveOrder[]
  pickTasks       PickTask[]

  @@unique([orgId, waveNumber])
  @@index([locationId])
  @@index([orgId])
  @@index([status])
}

model WaveOrder {
  id        String @id @default(uuid())
  waveId    String
  wave      Wave   @relation(fields: [waveId], references: [id], onDelete: Cascade)
  orderId   String
  priority  Int    @default(0)

  @@unique([waveId, orderId])
  @@index([waveId])
  @@index([orderId])
}

model PickTask {
  id              String   @id @default(uuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  waveId          String?
  wave            Wave?    @relation(fields: [waveId], references: [id])
  orderId         String?
  assignedToUserId String?
  status          String   @default("pending") // pending, assigned, in_progress, completed, short_pick, cancelled
  pickType        String                       // discrete, batch, zone
  zoneId          String?
  zone            WarehouseZone? @relation(fields: [zoneId], references: [id])
  zoneSequence    Int?                         // for sequential zone picking: 0, 1, 2... determines pass order
  totalLines      Int      @default(0)
  completedLines  Int      @default(0)
  startedAt       DateTime?
  completedAt     DateTime?                    // for SLA and performance analysis

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  pickLines       PickLine[]
  packTasks       PackTask[]

  @@index([locationId])
  @@index([orgId])
  @@index([waveId])
  @@index([status])
}

model PickLine {
  id                  String   @id @default(uuid())
  pickTaskId          String
  pickTask            PickTask @relation(fields: [pickTaskId], references: [id], onDelete: Cascade)
  orderId             String
  orderLineItemId     String
  inventoryRecordId   String
  inventoryRecord     InventoryRecord @relation(fields: [inventoryRecordId], references: [id])
  binId               String
  bin                 WarehouseBin @relation(fields: [binId], references: [id])
  trackableUnitId     String?
  trackableUnit       TrackableUnit? @relation(fields: [trackableUnitId], references: [id])
  sku                 String
  uomCode             String   @default("EA")
  requestedQuantity   Int
  pickedQuantity      Int      @default(0)
  status              String   @default("pending") // pending, picked, short, skipped
  walkSequence        Int      @default(0)
  lotNumber           String?
  shortPickAction     String?                      // backorder, substitute, cancel_line

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([pickTaskId])
  @@index([binId])
  @@index([walkSequence])
}

// ── Packing ──────────────────────────────────────────────────

model PackTask {
  id              String   @id @default(uuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  orderId         String
  pickTaskId      String?
  pickTask        PickTask? @relation(fields: [pickTaskId], references: [id])
  assignedToUserId String?
  packStationBinId String?
  packStationBin  WarehouseBin? @relation("PackStation", fields: [packStationBinId], references: [id])
  status          String   @default("pending") // pending, in_progress, completed, cancelled

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  packLines       PackLine[]

  @@index([locationId])
  @@index([orgId])
  @@index([orderId])
  @@index([status])
}

model PackLine {
  id                  String   @id @default(uuid())
  packTaskId          String
  packTask            PackTask @relation(fields: [packTaskId], references: [id], onDelete: Cascade)
  orderLineItemId     String
  trackableUnitId     String
  trackableUnit       TrackableUnit @relation(fields: [trackableUnitId], references: [id])
  sku                 String
  expectedQuantity    Int
  packedQuantity      Int      @default(0)
  status              String   @default("pending") // pending, verified, packed

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([packTaskId])
}

model CartonCatalogue {
  id              String   @id @default(uuid())
  locationId      String
  name            String                         // e.g. "Small Mailer", "Medium Box"
  lengthMm        Int
  widthMm         Int
  heightMm        Int
  maxWeightGrams  Int
  unitCostCents   Int?
  active          Boolean  @default(true)

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([locationId])
  @@index([orgId])
}

// ── Loading & Staging ────────────────────────────────────────

model StagingAssignment {
  id              String   @id @default(uuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  orderId         String
  shipmentId      String?
  trackableUnitId String
  trackableUnit   TrackableUnit @relation(fields: [trackableUnitId], references: [id])
  stagingBinId    String
  stagingBin      WarehouseBin @relation(fields: [stagingBinId], references: [id])
  loadSequence    Int?
  status          String   @default("staged") // staged, loading, loaded, dispatched

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([locationId])
  @@index([orgId])
  @@index([orderId])
  @@index([shipmentId])
  @@index([status])
}

// ── Load Planning ────────────────────────────────────────────

model LoadPlan {
  id              String   @id @default(uuid())
  locationId      String
  shipmentId      String?                      // target shipment (may be created during load plan)
  dockBinId       String?                      // assigned dock door
  status          String   @default("planning") // planning, loading, completed, cancelled
  sealNumber      String?                      // recorded on completion
  trailerNumber   String?
  carrierId       String?
  totalUnits      Int      @default(0)
  loadedUnits     Int      @default(0)
  completedAt     DateTime?
  bolDocumentId   String?                      // generated BOL document ID

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           LoadPlanLine[]

  @@index([locationId])
  @@index([orgId])
  @@index([shipmentId])
  @@index([status])
}

model LoadPlanLine {
  id              String   @id @default(uuid())
  loadPlanId      String
  loadPlan        LoadPlan @relation(fields: [loadPlanId], references: [id], onDelete: Cascade)
  stagingAssignmentId String?                  // link to staged unit
  trackableUnitId String?
  orderId         String
  loadSequence    Int      @default(0)         // reverse stop order: last delivery loaded first (low number = load first = back of truck)
  status          String   @default("pending") // pending, loaded, skipped

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([loadPlanId])
  @@index([loadSequence])
}

// ── Cycle Counting ───────────────────────────────────────────

model CycleCount {
  id              String   @id @default(uuid())
  locationId      String
  countType       String                       // full, zone, random_sample
  zoneId          String?                      // for zone counts
  status          String   @default("planned") // planned, in_progress, completed, cancelled
  assignedToUserId String?
  plannedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  totalBins       Int      @default(0)
  countedBins     Int      @default(0)
  varianceCount   Int      @default(0)         // bins with variances

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           CycleCountLine[]

  @@index([locationId])
  @@index([orgId])
  @@index([status])
}

model CycleCountLine {
  id                  String   @id @default(uuid())
  cycleCountId        String
  cycleCount          CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  binId               String
  sku                 String
  uomCode             String   @default("EA")
  expectedQuantity    Int                      // from InventoryRecord.quantityOnHand
  countedQuantity     Int?                     // null = not yet counted
  variance            Int?                     // counted - expected
  inventoryRecordId   String?                  // link to the InventoryRecord
  status              String   @default("pending") // pending, counted, variance_confirmed, adjusted
  countedByUserId     String?
  countedAt           DateTime?
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([cycleCountId])
  @@index([binId])
  @@index([status])
}

// ── Replenishment ────────────────────────────────────────────

model ReplenishmentRule {
  id              String   @id @default(uuid())
  locationId      String
  sku             String
  pickFaceBinId   String                       // bin to replenish
  bulkZoneId      String                       // zone to pull from
  minQuantity     Int                          // trigger when qty drops below this
  maxQuantity     Int                          // replenish up to this amount
  active          Boolean  @default(true)

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([locationId])
  @@index([orgId])
  @@index([sku])
}

// ── Manifest Ingestion ───────────────────────────────────────

model ManifestTemplate {
  id              String   @id @default(uuid())
  name            String                       // e.g. "Supplier X format", "FedEx ASN"
  headerChecksum  String                       // SHA-256 of sorted column headers for auto-detection
  columnMapping   Json                         // { sku: "Product Code", quantity: "Qty", ... }
  fileType        String   @default("csv")     // csv, xlsx
  delimiter       String?                      // for CSV: comma, tab, pipe
  hasHeaderRow    Boolean  @default(true)
  usageCount      Int      @default(0)         // how many times this template has been used

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  uploads         ManifestUpload[]

  @@unique([orgId, headerChecksum])
  @@index([orgId])
}

model ManifestUpload {
  id              String   @id @default(uuid())
  locationId      String                       // destination warehouse
  fileName        String
  fileStorageKey  String?                      // S3/DB storage key for the raw file
  status          String   @default("uploaded") // uploaded, mapped, processing, completed, failed
  templateId      String?
  template        ManifestTemplate? @relation(fields: [templateId], references: [id])
  receivingTaskId String?                      // created on processing
  totalRows       Int      @default(0)
  processedRows   Int      @default(0)
  errorRows       Int      @default(0)
  errors          Json?                        // [{ row: 5, field: "sku", message: "..." }]
  detectedHeaders Json?                        // column headers found in the file
  supplierName    String?
  reference       String?                      // BOL, PO number, etc.

  orgId           String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orgId])
  @@index([locationId])
  @@index([status])
}
