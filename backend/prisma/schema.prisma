generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id           String   @id @default(uuid())
  name         String
  contactEmail String?
  archived     Boolean  @default(false)
  archivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shipments    Shipment[]
  customerLanes CustomerLane[]
  orders       Order[]
  apiKeys      ApiKey[]
  tradingPartners TradingPartner[] @relation("CustomerTradingPartners")
  slaPolicies  SlaPolicy[]
  users        User[]

  // Billing & Financial
  billingEmail          String?
  billingAddress1       String?
  billingAddress2       String?
  billingCity           String?
  billingState          String?
  billingPostalCode     String?
  billingCountry        String?
  paymentTermsDays      Int       @default(30)    // Net 30, Net 45, etc.
  creditLimitCents      Int?                       // null = no limit
  currency              String   @default("USD")
  invoiceConsolidation  String   @default("per_shipment")  // per_shipment | weekly | monthly
  autoInvoice           Boolean  @default(false)            // auto-generate draft invoice on delivery
  taxId                 String?                             // VAT / EIN

  // Broker: Target Margin
  targetMarginPercent   Decimal?  @db.Decimal(5,2)          // Target margin % for this customer (e.g., 15.00)

  // Read model relations
  orderReadModels    OrderReadModel[]
  shipmentReadModels ShipmentReadModel[]

  // Financial relations
  quotes             Quote[]
  invoices           Invoice[]
  creditNotes        CreditNote[]  @relation("CustomerCreditNotes")

  // Custom fields
  customFieldVersionId String?              // Version of custom field definitions used
  customFieldValues    Json?                // { "fieldKey": value, ... }

  // WMS relations
  ownedTrackableUnits  TrackableUnit[]  @relation("OwnedUnits")
  ownedInventory       InventoryRecord[] @relation("InventoryOwner")

  // Customer Portal
  customerUsers        CustomerUser[]
}

model CustomerUser {
  id           String   @id @default(uuid())
  customer     Customer @relation(fields: [customerId], references: [id])
  customerId   String
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("viewer") // "viewer" | "admin"
  active       Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
  @@index([email])
}

model Location {
  id         String   @id @default(uuid())
  name       String
  address1   String
  address2   String?
  city       String
  state      String?
  postalCode String?
  country    String
  lat        Float?
  lng        Float?
  archived   Boolean  @default(false)
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Location classification & metadata
  locationType          String?  // warehouse, distribution_centre, cross_dock, terminal, port, rail_yard, customer, store, manufacturing
  facilityCapabilities  Json?    // { crossDockCapable, hasColdStorage, hasHazmatCert, hasBondedStorage }
  operatingHours        Json?    // Per-day schedule: { mon: { open: "08:00", close: "17:00" }, ... }
  appointmentRequired   Boolean  @default(false)
  dockCount             Int?
  maxTrailerLengthFt    Int?

  // Contact
  contactName   String?
  contactPhone  String?
  contactEmail  String?

  // Relations
  originFor  Shipment[] @relation("Origin")
  destFor    Shipment[] @relation("Destination")
  lanesAsOrigin Lane[] @relation("LaneOrigin")
  lanesAsDestination Lane[] @relation("LaneDestination")
  laneStops  LaneStop[]
  orderOriginFor Order[] @relation("OrderOrigin")
  orderDestFor   Order[] @relation("OrderDestination")
  pendingLaneRequestsAsOrigin PendingLaneRequest[] @relation("PendingLaneOrigin")
  pendingLaneRequestsAsDestination PendingLaneRequest[] @relation("PendingLaneDestination")
  shipmentStops  ShipmentStop[] // Multi-stop shipment support
  arrivalCriteria ArrivalCriteria[] // Arrival criteria for this location

  // Custom fields
  customFieldVersionId String?
  customFieldValues    Json?

  // Warehouse app preferences
  preferredLocationId  String?            // Favourite origin location for warehouse app

  // WMS relations
  warehouseZones       WarehouseZone[]
  warehouseAisles      WarehouseAisle[]
  warehouseBins        WarehouseBin[]
  inventoryRecords     InventoryRecord[]
  receivingAppointments ReceivingAppointment[]
  receivingTasks       ReceivingTask[]
  putawayRules         PutawayRule[]
  putawayTasks         PutawayTask[]
  waveTemplates        WaveTemplate[]
  waves                Wave[]
  pickTasks            PickTask[]
  packTasks            PackTask[]
  stagingAssignments   StagingAssignment[]
}

model Shipment {
  id            String   @id @default(uuid())
  reference     String
  status        String   @default("draft")
  pickupDate    DateTime?
  deliveryDate  DateTime?
  proNumber     String?
  items         Json?
  archived      Boolean  @default(false)
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id])
  customerId    String
  origin        Location @relation("Origin", fields: [originId], references: [id])
  originId      String
  destination   Location @relation("Destination", fields: [destinationId], references: [id])
  destinationId String
  lane          Lane?    @relation(fields: [laneId], references: [id])
  laneId        String?
  carrier       Carrier? @relation(fields: [carrierId], references: [id])
  carrierId     String?  // Manual carrier assignment for non-lane shipments
  loads         Load[]
  events        ShipmentEvent[]
  orderShipments OrderShipment[]
  stops         ShipmentStop[] // Multi-stop route support
  tenders       Tender[] // Carrier tenders for this shipment
  deviceAssignments DeviceAssignment[]    // IoT device assignments
  sensorReadings    SensorReading[]       // Sensor telemetry data

  // Cargo tracking
  cargoScans        CargoScan[]
  cargoDiscrepancies CargoDiscrepancy[]

  // Read model relations
  orderReadModels    OrderReadModel[]

  // Cold chain
  coldChainProfile      ColdChainProfile? @relation(fields: [coldChainProfileId], references: [id])
  coldChainProfileId    String?
  effectiveMinTemp      Float?            // Computed from orders or profile (°C canonical)
  effectiveMaxTemp      Float?
  effectiveAlertMinTemp Float?            // Warning thresholds (tighter than min/max)
  effectiveAlertMaxTemp Float?
  coldChainDisposition  String            @default("not_applicable") // not_applicable, monitoring, pending_review, released, quarantined
  dispositionSetBy      String?
  dispositionSetAt      DateTime?
  dispositionNotes      String?
  temperatureLogs       ImmutableTemperatureLog[]
  coldChainExcursions   ColdChainExcursion[]
  capaReports           CAPAReport[]

  // Custom fields
  customFieldVersionId String?
  customFieldValues    Json?

  // Financial
  charges                Charge[]
  shipmentFinancialSummary ShipmentFinancialSummary?

  // Warehouse app
  accessories       ShipmentAccessory[]  // Door seals, BLE sensors, etc.
  flags             ShipmentFlag[]       // Warehouse user flagged issues
  launchedAt        DateTime?            // When warehouse user completed launch workflow
  launchedBy        String?              // User ID who launched

  // Carrier tracking API
  trackingNumber          String?              // Carrier tracking number (PRO, AWB, etc.)
  carrierTrackingEvents   CarrierTrackingEvent[]

  // Brokerage
  commissions             Commission[]
}

model ShipmentStop {
  id                String    @id @default(uuid())
  shipment          Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId        String
  location          Location  @relation(fields: [locationId], references: [id])
  locationId        String

  // Stop sequence in the route (1 = first stop, 2 = second, etc.)
  sequenceNumber    Int

  // Type of stop
  stopType          String    @default("delivery") // pickup, delivery, both

  // Timing
  estimatedArrival  DateTime?
  actualArrival     DateTime?
  estimatedDeparture DateTime?
  actualDeparture   DateTime?

  // Status
  status            String    @default("pending") // pending, arrived, in_progress, completed, skipped

  // Orders to be delivered at this stop
  orders            Order[]

  // Geofencing (for automatic status updates)
  geofenceRadius    Float?    // Radius in meters for geofence trigger
  geofenceEnabled   Boolean   @default(false)

  // Notes and instructions
  notes             String?
  instructions      String?   // Specific delivery instructions for this stop

  // Proof of delivery
  signatureUrl      String?   // URL to signature image
  photoUrls         Json?     // Array of photo URLs
  proofOfDelivery   Json?     // Additional proof data

  // Cargo tracking relations
  cargoScans            CargoScan[]
  discrepanciesExpected CargoDiscrepancy[] @relation("ExpectedStop")
  discrepanciesActual   CargoDiscrepancy[] @relation("ActualStop")
  trackableUnitsHere    TrackableUnit[]    @relation("UnitCurrentStop")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([shipmentId, sequenceNumber])
  @@index([shipmentId])
  @@index([locationId])
  @@index([status])
}

// ─── Arrival Criteria ─────────────────────────────────────────────────────────
// Every location should have at least one arrival criteria to determine
// when a shipment has arrived. Types: geofence, wifi, ble (Bluetooth anchor).

model ArrivalCriteria {
  id          String   @id @default(uuid())
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId  String

  // Criteria type
  criteriaType String  // "geofence", "wifi", "ble"

  // Geofence criteria
  radiusMeters Float?  // Radius in meters for geofence trigger
  lat          Float?  // Center latitude (defaults to location lat if null)
  lng          Float?  // Center longitude (defaults to location lng if null)

  // WiFi criteria (IoT device detects a known WiFi network)
  wifiSsid     String? // WiFi network name (SSID)
  wifiBssid    String? // WiFi access point MAC address (BSSID) for precise identification

  // BLE criteria (Bluetooth Low Energy location anchor / reader)
  bleUuid      String? // BLE beacon UUID
  bleMajor     Int?    // BLE beacon major value
  bleMinor     Int?    // BLE beacon minor value
  bleRssiThreshold Int? // RSSI threshold for proximity detection (e.g., -70 dBm)
  bleAnchorId  String? // Fixed anchor/reader ID at this location (matches device reports)
  bleReaderLocation String? // Where the reader is at this location (e.g., "Loading Dock B")

  // Metadata
  name         String? // Optional friendly name (e.g., "Loading Dock A WiFi")
  active       Boolean @default(true)
  priority     Int     @default(0) // Higher priority criteria checked first

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([locationId])
  @@index([criteriaType])
  @@index([locationId, active])
}

model ShipmentEvent {
  id              String   @id @default(uuid())
  shipment        Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId      String
  eventType       String   // "location", "status_change", "note", etc.
  deviceId        String?  // External device ID (e.g., "72308628872889491")
  deviceName      String?  // Device display name (e.g., "SH-0001")
  lat             Float?   // Latitude from GPS
  lng             Float?   // Longitude from GPS
  address         String?  // Human-readable address
  locationSummary String?  // Full location summary from webhook
  rawPayload      Json?    // Store the entire webhook payload for debugging
  eventTime       DateTime // When the event occurred (from webhook)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shipmentId])
  @@index([eventTime])
}

model Carrier {
  id           String   @id @default(uuid())
  name         String
  mcNumber     String?
  dotNumber    String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  address1     String?
  address2     String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  archived     Boolean  @default(false)
  archivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  vehicles     Vehicle[]
  drivers      Driver[]
  laneCarriers LaneCarrier[]
  shipments    Shipment[]

  // Carrier Validation (SOP-CL-001)
  validationTier            String?    // "tier1" | "tier2" | "tier3" | null
  registrationChecked       Boolean    @default(false)
  insuranceDocReceived      Boolean    @default(false)
  insuranceVerified         Boolean    @default(false)
  identityConfirmed         Boolean    @default(false)
  complianceChecked         Boolean    @default(false)
  validationNotes           String?
  validatedAt               DateTime?
  validatedBy               String?

  // Standard Carrier Alpha Code (needed for EDI 204)
  scacCode     String?

  // Payment & Remittance
  paymentTermsDays      Int       @default(30)
  remitToName           String?
  remitToAddress1       String?
  remitToCity           String?
  remitToState          String?
  remitToPostalCode     String?
  remitToCountry        String?
  currency              String   @default("USD")

  // Custom fields
  customFieldVersionId String?
  customFieldValues    Json?

  // Tendering relations
  carrierUsers   CarrierUser[]
  tenderOffers   TenderOffer[]
  tenderBids     TenderBid[]
  tradingPartners TradingPartner[] @relation("CarrierTradingPartners")

  // Financial relations
  carrierInvoices  CarrierInvoice[]
  creditNotes      CreditNote[]  @relation("CarrierCreditNotes")

  // Read model relations
  shipmentReadModels ShipmentReadModel[]

  // Carrier tracking API integration
  trackingIntegration CarrierTrackingIntegration?
  trackingEvents      CarrierTrackingEvent[]
}

model Vehicle {
  id         String   @id @default(uuid())
  carrier    Carrier  @relation(fields: [carrierId], references: [id])
  carrierId  String
  plate      String
  type       String
  capacityKg Int?
  capacityM3 Int?
  loads      Load[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Driver {
  id        String   @id @default(uuid())
  carrier   Carrier  @relation(fields: [carrierId], references: [id])
  carrierId String
  name      String
  phone     String?
  email     String?
  loads     Load[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Load {
  id         String   @id @default(uuid())
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
  shipmentId String
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId  String?
  driver     Driver?  @relation(fields: [driverId], references: [id])
  driverId   String?
  assignedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lane {
  id            String   @id @default(uuid())
  name          String   // Auto-generated: "Origin → Destination"
  origin        Location @relation("LaneOrigin", fields: [originId], references: [id])
  originId      String
  destination   Location @relation("LaneDestination", fields: [destinationId], references: [id])
  destinationId String
  distance      Float?   // Optional distance in km
  notes         String?

  // Lane capabilities for order matching
  serviceLevel          String    @default("LTL") // "FTL", "LTL", or "Both"
  supportsTemperatureControl Boolean @default(false) // Can handle refrigerated/frozen
  supportsHazmat        Boolean   @default(false) // Hazmat certified
  maxWeight             Float?    // Maximum weight capacity in kg
  maxVolume             Float?    // Maximum volume capacity in m³

  status        String   @default("active") // active/archived
  archived      Boolean  @default(false)
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  shipments     Shipment[]
  customerLanes CustomerLane[]
  laneCarriers  LaneCarrier[]
  stops         LaneStop[]
  route         LaneRoute?

  // Read model relations
  shipmentReadModels ShipmentReadModel[]
}

model CustomerLane {
  id         String   @id @default(uuid())
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String
  lane       Lane     @relation(fields: [laneId], references: [id])
  laneId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, laneId])
}

model LaneCarrier {
  id           String   @id @default(uuid())
  lane         Lane     @relation(fields: [laneId], references: [id])
  laneId       String
  carrier      Carrier  @relation(fields: [carrierId], references: [id])
  carrierId    String
  price        Float?   // Price per shipment or per km (deprecated — use priceCents)
  priceCents   Int?     // Price in cents — canonical field for financial calculations
  currency     String   @default("USD")
  serviceLevel String?  // e.g., "Standard", "Express", "Economy"
  notes        String?
  assigned     Boolean  @default(false) // True if this carrier is assigned to the lane
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Contract rate fields
  rateType              String?   // "per_mile" | "flat" | "cwt"
  contractStartDate     DateTime?
  contractEndDate       DateTime?
  fuelSurchargePercent  Float?
  accessorialRates      Json?     // { "detention": 50, "lumper": 75, ... }
  isContractRate        Boolean   @default(false)

  // Broker: Target margin for this lane-carrier combo
  targetMarginPercent   Decimal?  @db.Decimal(5,2)

  @@unique([laneId, carrierId])
}

model LaneStop {
  id         String   @id @default(uuid())
  lane       Lane     @relation(fields: [laneId], references: [id], onDelete: Cascade)
  laneId     String
  location   Location @relation(fields: [locationId], references: [id])
  locationId String
  order      Int      // Order of the stop in the lane (1, 2, 3, etc.)
  notes      String?  // Optional notes for this specific stop
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([laneId, order])
  @@unique([laneId, locationId])
}

model Order {
  id                    String   @id @default(uuid())
  orderNumber           String   @unique // Customer's order number or our generated number
  poNumber              String?  // Purchase order number
  status                String   @default("pending") // pending, validated, location_error, converted, cancelled, archived
  importSource          String   @default("manual") // manual, csv, edi
  ediData               Json?    // Store original EDI data if imported via EDI

  customer              Customer @relation(fields: [customerId], references: [id])
  customerId            String

  // Origin and destination - nullable because location might not exist yet
  origin                Location? @relation("OrderOrigin", fields: [originId], references: [id])
  originId              String?
  originData            Json?     // Store raw location data if location doesn't exist
  originValidated       Boolean   @default(false)

  destination           Location? @relation("OrderDestination", fields: [destinationId], references: [id])
  destinationId         String?
  destinationData       Json?     // Store raw location data if location doesn't exist
  destinationValidated  Boolean   @default(false)

  // Dates
  orderDate             DateTime  @default(now())
  requestedPickupDate   DateTime?
  requestedDeliveryDate DateTime?

  // Special requirements for shipment assignment
  serviceLevel          String    @default("LTL") // "FTL" (Full Truck Load) or "LTL" (Less Than Truck Load)
  temperatureControl    String    @default("ambient") // "ambient", "refrigerated", "frozen"
  requiresHazmat        Boolean   @default(false)
  specialRequirements   Json?     // Additional requirements as JSON array

  // Delivery status tracking (separate from order lifecycle status)
  deliveryStatus        String    @default("unassigned") // unassigned, assigned, in_transit, delivered, exception, cancelled
  deliveredAt           DateTime? // When the order was delivered
  deliveryConfirmedBy   String?   // User ID or system identifier who confirmed delivery
  deliveryMethod        String?   // manual, geofence, geofence_iot, auto, driver_app
  deliveryNotes         String?   // Notes about the delivery
  exceptionType         String?   // If exception status: delay, damage, refused, address_issue, weather, other
  exceptionNotes        String?   // Details about the exception
  exceptionResolvedAt   DateTime? // When the exception was resolved

  // Link to the specific stop where this order should be delivered (for multi-stop shipments)
  deliveryStop          ShipmentStop? @relation(fields: [deliveryStopId], references: [id])
  deliveryStopId        String?

  // Trackable units (pallets, totes, boxes, etc.)
  trackableUnits        TrackableUnit[]

  // Line items (legacy - will be moved to trackable units)
  lineItems             OrderLineItem[]

  // Additional info
  specialInstructions   String?
  notes                 String?

  // Tracking
  archived              Boolean   @default(false)
  archivedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relationship to shipments
  orderShipments        OrderShipment[]

  // Audit trail
  auditLogs             AuditLog[]

  // Pending lane requests
  pendingLaneRequests   PendingLaneRequest[]

  // IoT device tracking
  deviceAssignments     DeviceAssignment[]
  sensorReadings        SensorReading[]

  // Financial
  charges               Charge[]

  // Custom fields
  customFieldVersionId String?
  customFieldValues    Json?
}

model OrderLineItem {
  id          String  @id @default(uuid())
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String

  // Optional: which trackable unit does this item belong to?
  trackableUnit   TrackableUnit? @relation(fields: [trackableUnitId], references: [id], onDelete: Cascade)
  trackableUnitId String?

  sku         String
  description String?
  quantity    Int
  weight      Float?  // in kg
  weightUnit  String  @default("kg")
  length      Float?  // dimensions in cm
  width       Float?
  height      Float?
  dimUnit     String  @default("cm")

  // Additional fields
  hazmat      Boolean @default(false)
  temperature String? // e.g., "ambient", "refrigerated", "frozen"

  // Pricing
  unitPriceCents  Int?                  // Price per unit in cents
  totalPriceCents Int?                  // quantity * unitPriceCents
  priceCurrency   String  @default("USD")

  // LTL classification
  freightClass    String?               // 50, 55, 60, 65, 70, 77.5, 85, 92.5, 100, 110, 125, 150, 175, 200, 250, 300, 400, 500
  nmfcCode        String?               // National Motor Freight Classification code

  // WMS relations
  allocations     Allocation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrderShipment {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  shipment    Shipment @relation(fields: [shipmentId], references: [id])
  shipmentId  String
  createdAt   DateTime @default(now())

  @@unique([orderId, shipmentId])
}

model Organization {
  id                  String   @id @default(uuid())
  name                String   @default("Default Organization")

  // Organization Type
  organizationType    String   @default("shipper") // "shipper" | "broker" | "carrier" | "3pl"

  // Broker-Specific Fields
  mcNumber            String?                      // Motor Carrier number
  bondAmountCents     Int?                         // Bond amount in cents
  bondExpirationDate  DateTime?                    // Bond expiration date
  operatingAuthorityStatus String? @default("active") // "active" | "pending" | "revoked"

  // Broker Margin Configuration
  minMarginPercent    Decimal? @db.Decimal(5,2)    // Minimum acceptable margin % (e.g., 10.00)
  marginAlertEnabled  Boolean  @default(false)     // Enable margin alert issues

  // Lowest Trackable Unit Configuration
  trackingMode        String   @default("item") // "group" or "item"
  trackableUnitType   String   @default("box") // "pallet", "tote", "box", "stillage", "custom"
  customUnitName      String?  // Used when trackableUnitType is "custom"

  // Unit of Measure Configuration (system-level defaults)
  weightUnit          String   @default("kg")   // "kg" or "lb"
  dimUnit             String   @default("cm")   // "cm" or "in"
  temperatureUnit     String   @default("C")    // "C" or "F"
  distanceUnit        String   @default("km")   // "km" or "mi"

  // BOL sequence counter for auto-numbering
  bolSequenceNumber   Int      @default(0)

  // Theme & Branding
  logoStorageKey      String?                     // Opaque key for logo in IBinaryStorageProvider
  logoMimeType        String?                     // "image/png", "image/svg+xml", etc.
  themeConfig         Json?                       // Full CSS custom property overrides (see ThemeConfig)
  themeUpdatedAt      DateTime?                   // Used for cache invalidation

  // Carrier Tendering
  autoTenderEnabled   Boolean  @default(false)  // Auto-publish tenders for laneless shipments
  defaultGeofenceRadiusMeters Float @default(200) // Default geofence radius for new locations

  // Cold Chain & Compliance
  autoDeliverShipmentDocs Boolean @default(false) // Auto-deliver compliance docs to customers on shipment complete

  // Warehouse App
  magicLinksEnabled   Boolean  @default(true)  // Allow QR code / magic link login
  warehouseScanMode   String   @default("hid") // "hid" (built-in scanner) or "camera"

  // Maps & Geocoding
  googleMapsApiKey    String?   // Google Maps API key for Places + Geocoding

  // Email Branding
  emailHeaderHtml     String?  // Custom HTML for email header (replaces default logo/name header)
  emailFooterHtml     String?  // Custom HTML for email footer (replaces default "Sent by..." footer)

  // Email Configuration
  emailProvider       String   @default("console") // "smtp" | "sendgrid" | "ses" | "console"
  smtpHost            String?
  smtpPort            Int?
  smtpSecure          Boolean  @default(false)
  smtpUser            String?
  smtpPassword        String?                      // Encrypted at rest in production
  emailFromAddress    String?                      // Default "from" address
  emailFromName       String?                      // Default "from" display name
  emailEnabled        Boolean  @default(false)     // Global kill switch

  // AI / LLM Configuration (for agent features)
  llmProvider         String?                      // "anthropic" (more providers in future)
  llmApiKey           String?                      // API key — masked in API responses, encrypted at rest in production
  llmModel            String?                      // Model override, e.g. "claude-sonnet-4-20250514"
  llmEnabled          Boolean  @default(false)     // Global kill switch for AI agents

  // Metadata
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users               User[]
  emailTemplates      EmailTemplate[]

  // Issue & Read model relations
  issues              Issue[]
  carrierReadModels   CarrierReadModel[]
  customerReadModels  CustomerReadModel[]
  issueReadModels     IssueReadModel[]
  laneReadModels      LaneReadModel[]
  orderReadModels     OrderReadModel[]
  shipmentReadModels  ShipmentReadModel[]

  // Agent Decision relations
  agentDecisions          AgentDecision[]
  agentDecisionReadModels AgentDecisionReadModel[]
  agentConfigs            AgentConfig[]
  automationRules         AutomationRule[]
  skillConfigs            SkillConfig[]
  skillChains             SkillChain[]
}

model TrackableUnit {
  id              String   @id @default(uuid())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String

  // Unit identification
  identifier      String   // e.g., "PALLET-001", "BOX-123", user-defined identifier
  unitType        String   // Snapshot of the org setting at creation time (pallet, tote, box, stillage, custom)
  customTypeName  String?  // If custom type was used

  // Sequence number within the order
  sequenceNumber  Int      // 1, 2, 3... for ordering within an order

  // Line items contained in this unit
  lineItems       OrderLineItem[]

  // Additional tracking
  barcode         String?  // Optional barcode/QR code
  notes           String?

  // IoT device tracking at unit level
  sensorReadings  SensorReading[]
  deviceEvents    DeviceEvent[]

  // Cargo tracking — where this unit physically is right now
  currentStopId   String?          // Which stop this unit is currently at (null = in transit / on vehicle)
  currentStop     ShipmentStop?    @relation("UnitCurrentStop", fields: [currentStopId], references: [id])
  condition       String           @default("good") // good, damaged, lost, unknown
  lastScannedAt   DateTime?

  // Cargo scan & discrepancy relations
  cargoScans      CargoScan[]
  discrepancies   CargoDiscrepancy[]

  // WMS fields
  currentBinId    String?
  currentBin      WarehouseBin?    @relation("UnitCurrentBin", fields: [currentBinId], references: [id])
  parentUnitId    String?
  parentUnit      TrackableUnit?   @relation("UnitNesting", fields: [parentUnitId], references: [id])
  childUnits      TrackableUnit[]  @relation("UnitNesting")
  currentZoneId   String?
  currentZone     WarehouseZone?   @relation("UnitCurrentZone", fields: [currentZoneId], references: [id])
  lotNumber       String?
  expiryDate      DateTime?
  receivedAt      DateTime?
  ownerCustomerId String?
  ownerCustomer   Customer?        @relation("OwnedUnits", fields: [ownerCustomerId], references: [id])
  qualityStatus   String           @default("available") // available, hold, quarantine, damaged

  // WMS task relations
  putawayTasks    PutawayTask[]
  receivingLines  ReceivingLine[]
  pickLines       PickLine[]
  packLines       PackLine[]
  allocations     Allocation[]
  inventoryTransactions InventoryTransaction[]
  stagingAssignments    StagingAssignment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orderId, sequenceNumber])
  @@index([orderId])
  @@index([currentStopId])
  @@index([currentBinId])
  @@index([currentZoneId])
  @@index([parentUnitId])
  @@index([ownerCustomerId])
  @@index([lotNumber])
}

model AuditLog {
  id          String   @id @default(uuid())

  // Entity tracking
  entityType  String   // "order", "trackable_unit", "line_item"
  entityId    String   // ID of the affected entity
  orderId     String?  // Reference to order for easy filtering
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Action details
  action      String   // "created", "updated", "deleted", "converted", "moved", etc.
  description String   // Human-readable description
  changes     Json?    // JSON object with before/after values

  // User tracking
  user        User?    @relation("AuditUser", fields: [userId], references: [id])
  userId      String?  // User who performed the action
  userName    String?  // Name of the user (denormalized for display)

  // Metadata
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PendingLaneRequest {
  id          String   @id @default(uuid())

  // Order that triggered this request
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String

  // Lane details needed
  originId      String
  origin        Location @relation("PendingLaneOrigin", fields: [originId], references: [id])
  destinationId String
  destination   Location @relation("PendingLaneDestination", fields: [destinationId], references: [id])

  // Required capabilities
  serviceLevel          String   // "FTL" or "LTL"
  requiresTemperatureControl Boolean @default(false)
  requiresHazmat        Boolean  @default(false)

  // Status tracking
  status        String   @default("pending") // "pending", "approved", "rejected", "lane_created"
  resolvedAt    DateTime?
  resolvedById  String?  // User who resolved this request
  createdLaneId String?  // If approved and lane was created

  // Notes
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([originId, destinationId])
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String   // User-friendly name for the API key
  keyHash     String   @unique // Hashed version of the API key
  keyPrefix   String   // First 8 characters for display (e.g., "sk_live_...")
  active      Boolean  @default(true)
  customer    Customer? @relation(fields: [customerId], references: [id])
  customerId  String?   // Links API key to a specific customer for scoped access
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  webhookLogs WebhookLog[]

  @@index([active])
  @@index([createdAt])
  @@index([customerId])
}

model WebhookLog {
  id                String   @id @default(uuid())
  apiKey            ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  apiKeyId          String?
  
  // Request details
  method            String   // HTTP method (POST, etc.)
  path              String?
  ipAddress         String?
  userAgent         String?
  headers           Json?    // Request headers (redacted API key)
  
  // Payload details
  deviceName        String?  // Extracted device name from payload
  deviceId          String?  // Device ID from payload
  eventType         String?  // Event type (location, etc.)
  hasLocation       Boolean  @default(false) // Whether lat/lng were provided
  lat               Float?
  lng               Float?
  rawPayload        Json?    // Full request body
  
  // Processing results
  status            String   // "success", "error", "skipped", "not_found"
  shipmentFound     Boolean  @default(false)
  shipmentUpdated   Boolean  @default(false)
  shipmentId        String?  // ID of shipment if found
  shipmentReference String?  // Reference of shipment if found
  shipmentEventId   String?  // ID of created ShipmentEvent if any
  errorMessage      String?  // Error message if status is "error"
  
  // Response
  responseCode      Int?     // HTTP response code
  responseBody      Json?    // Response body sent back
  
  // Timestamps
  receivedAt        DateTime @default(now())
  processedAt       DateTime?
  
  @@index([apiKeyId])
  @@index([status])
  @@index([shipmentId])
  @@index([receivedAt])
  @@index([deviceName])
}


// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String?  // Null for OAuth-only users
  firstName      String
  lastName       String
  active         Boolean  @default(true)

  // OAuth provider (null = local password auth)
  authProvider   String?  // "google", "microsoft", or null for local
  authProviderId String?  // External user ID from the OAuth provider

  // Organization
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  // Optional link to customer (for customer-portal users)
  customer       Customer? @relation(fields: [customerId], references: [id])
  customerId     String?

  // Profile
  avatarUrl      String?
  phone          String?
  timezone       String   @default("UTC")

  // Unit of measure preferences (null = use organization default)
  weightUnit     String?                    // "kg" or "lb"
  dimUnit        String?                    // "cm" or "in"
  temperatureUnit String?                   // "C" or "F"
  distanceUnit   String?                    // "km" or "mi"

  // Auth metadata
  lastLoginAt    DateTime?
  passwordChangedAt DateTime?
  failedLoginAttempts Int  @default(0)
  lockedUntil    DateTime?

  // Warehouse app preferences
  preferredLocationId  String?            // Favourite origin location for warehouse app

  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationships
  roles          UserRole[]
  sessions       Session[]
  auditLogs      AuditLog[] @relation("AuditUser")
  magicLinks     MagicLink[]
  loginAuditLogs LoginAuditLog[]
  commissions    Commission[]

  @@index([email])
  @@index([organizationId])
  @@index([customerId])
  @@index([active])
  @@unique([authProvider, authProviderId])
}

model AuthProvider {
  id           String   @id @default(uuid())
  provider     String   @unique // "google", "microsoft"
  displayName  String   // "Google", "Microsoft"
  enabled      Boolean  @default(false)

  // OAuth credentials (set by admin)
  clientId     String?
  clientSecret String?

  // Provider-specific config
  tenantId     String?  // Microsoft: Azure AD tenant ID (blank = common)
  allowedDomains Json?  // Optional: restrict to specific email domains e.g. ["company.com"]

  // Auto-provisioning
  autoCreateUsers   Boolean @default(true)  // Create user on first OAuth login
  defaultRoleId     String? // Role to assign to auto-created users

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // admin, dispatcher, warehouse, readonly, customer
  description String?
  permissions Json     // Array of permission strings e.g. ["shipments:read", "shipments:write", "orders:*"]
  isSystem    Boolean  @default(false) // System roles can't be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
}

model UserRole {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    String
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Session {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  tokenHash    String   @unique // SHA-256 hash of the refresh token
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── EDI Models ──────────────────────────────────────────────────────────────


// ─── Binary Storage (fallback when S3 not configured) ───────────────────────

model BinaryStore {
  key       String   @id       // S3-style key path e.g. "attachments/shipment/abc/file.pdf"
  content   Bytes
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Attachment Models ──────────────────────────────────────────────────────

model Attachment {
  id              String   @id @default(uuid())
  entityType      String                        // "shipment", "order", "carrier", "customer", "location"
  entityId        String
  fileName        String                        // Original filename (for Content-Disposition only)
  mimeType        String
  fileSize        Int
  storageKey      String                        // Opaque UUID-based key — no entity info or filenames
  storageBackend  String   @default("s3")       // "s3" or "database"
  uploadedBy      String?                       // userId
  description     String?
  retentionExpiresAt DateTime?                  // Default: 10 years from creation. Null = indefinite.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([retentionExpiresAt])
}

// ─── Document Models ────────────────────────────────────────────────────────

model DocumentTemplate {
  id              String   @id @default(uuid())
  name            String                        // "Standard BOL", "International Customs"
  documentType    String                        // "bol", "label", "customs", "daily_report"
  description     String?

  // Template content — HTML with Handlebars placeholders
  htmlTemplate    String

  // Configuration — JSON blob for type-specific settings
  config          Json?                         // e.g. { "pageSize": "letter", "orientation": "portrait" }

  // Metadata
  isDefault       Boolean  @default(false)      // One default per documentType
  active          Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documents       GeneratedDocument[]

  @@index([documentType])
  @@index([active])
}

model GeneratedDocument {
  id              String   @id @default(uuid())

  // What kind of document
  documentType    String                        // "bol", "label", "customs", "daily_report", "attachment"
  documentNumber  String?                       // Auto-generated BOL number, etc.
  fileName        String                        // "BOL-20260329-0001.pdf"
  mimeType        String   @default("application/pdf")
  fileSize        Int?                          // bytes

  // Storage — binary content (optional: new docs use external storage via storageKey)
  fileContent     Bytes?
  storageKey      String?                       // Opaque UUID-based key — no entity info or filenames
  storageBackend  String   @default("database") // "s3" or "database"

  // Template used (null for attachments/uploads)
  template        DocumentTemplate? @relation(fields: [templateId], references: [id])
  templateId      String?

  // Entity associations (polymorphic — at least one should be set)
  shipmentId      String?
  orderId         String?
  carrierId       String?
  customerId      String?

  // Who generated/uploaded it
  generatedBy     String?                       // userId

  // Metadata
  metadata        Json?                         // Snapshot of data used to generate
  notes           String?

  // Retention
  retentionExpiresAt DateTime?                  // Default: 10 years from creation. Null = indefinite.

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shipmentId])
  @@index([orderId])
  @@index([carrierId])
  @@index([customerId])
  @@index([documentType])
  @@index([createdAt])
  @@index([retentionExpiresAt])
}

// ─── Custom Fields (Versioned) ──────────────────────────────────────────────

model CustomFieldVersion {
  id          String   @id @default(uuid())
  entityType  String                        // "shipment", "order", "carrier", "customer", "location"
  version     Int                           // Auto-incremented per entityType
  description String?                       // E.g., "Added invoice number field"
  createdBy   String?                       // userId who created this version
  active      Boolean  @default(true)       // Only one active version per entityType

  createdAt   DateTime @default(now())

  fields      CustomFieldDefinition[]

  @@unique([entityType, version])
  @@index([entityType, active])
}

model CustomFieldDefinition {
  id          String   @id @default(uuid())
  version     CustomFieldVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId   String

  // Field identity
  fieldKey    String                        // Machine-readable key, e.g. "invoice_number" (stable across versions)
  label       String                        // Display label, e.g. "Invoice Number"
  description String?                       // Help text shown to users

  // Field type and configuration
  fieldType   String                        // "text", "decimal", "integer", "date", "boolean", "list", "multi_list"
  required    Boolean  @default(false)
  defaultValue String?                      // Stored as string, parsed by type

  // Type-specific configuration (JSON)
  config      Json?                         // {
                                            //   text: { minLength, maxLength, formatMask, pattern }
                                            //   decimal: { minValue, maxValue, decimalPlaces }
                                            //   integer: { minValue, maxValue }
                                            //   list/multi_list: { options: ["opt1","opt2",...] }
                                            //   date: { minDate, maxDate }
                                            // }

  // Display
  displayOrder Int     @default(0)          // Sort order in forms/views

  createdAt   DateTime @default(now())

  @@unique([versionId, fieldKey])
  @@index([versionId])
}

model CustomFieldAudit {
  id          String   @id @default(uuid())
  entityType  String
  action      String                        // "version_created", "field_added", "field_modified", "field_removed"
  versionId   String?                       // New version ID
  previousVersionId String?                 // Previous version ID
  changes     Json?                         // Details of what changed
  performedBy String?                       // userId
  createdAt   DateTime @default(now())

  @@index([entityType])
  @@index([createdAt])
}

// ============================================================
// Domain Events — immutable event store
// ============================================================

model DomainEventLog {
  id          String   @id
  type        String                          // "shipment.status_changed", "order.created", etc.
  timestamp   String                          // ISO-8601 when the event occurred
  orgId       String                          // Organization scope
  actorId     String?                         // User or system that caused the event
  entityType  String                          // "shipment", "order", "carrier", etc.
  entityId    String                          // PK of the changed entity
  payload     Json                            // Event-specific data
  metadata    Json                            // correlationId, causationId, source, schemaVersion
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([entityType, entityId])
  @@index([orgId])
  @@index([timestamp])
  @@index([createdAt])
}

// ============================================================
// Notifications — in-app notification inbox
// ============================================================

model Notification {
  id          String   @id @default(uuid())
  userId      String
  orgId       String
  title       String                          // "Shipment SH-0042 Exception"
  body        String                          // Descriptive message
  category    String                          // "shipment_update", "order_update", "exception", "triage", "system"
  severity    String   @default("info")       // "info", "warning", "error", "success"
  entityType  String?                         // Link to source entity
  entityId    String?
  actionUrl   String?                         // Deep link: "/shipments/abc-123"
  eventId     String?                         // Reference to DomainEventLog.id
  eventType   String?                         // "shipment.exception"
  read        Boolean  @default(false)
  readAt      DateTime?
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([orgId])
}

// ============================================================
// Event Subscriptions — org-level rules for event routing
// ============================================================

model EventSubscription {
  id           String   @id @default(uuid())
  orgId        String
  name         String                         // "Email on shipment exceptions"
  active       Boolean  @default(true)
  eventPattern String                         // "shipment.exception", "order.*", "*"
  handlerType  String                         // "email", "inapp", "webhook"
  config       Json                           // Handler-specific: template, recipients, URL, etc.
  entityFilter Json?                          // Optional: filter by entity properties
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId, active])
  @@index([eventPattern])
}

// ============================================================
// User Notification Preferences — per-user channel settings
// ============================================================

model UserNotificationPreference {
  id            String   @id @default(uuid())
  userId        String
  eventCategory String                        // "shipment_updates", "exceptions", "triage", "system"
  emailEnabled  Boolean  @default(true)
  inAppEnabled  Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, eventCategory])
}

// ─── Email Templates ─────────────────────────────────────────────

model EmailTemplate {
  id              String   @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  // Template identification
  name            String                         // "Shipment Status Update", "Delivery Confirmation"
  eventType       String                         // Event type this template handles: "shipment.status_changed", "shipment.delivered", etc.
  description     String?

  // Content (Handlebars)
  subject         String                         // Subject line template: "Shipment {{shipmentReference}} — {{newStatus}}"
  htmlBody        String                         // HTML body with Handlebars placeholders
  textBody        String?                        // Plain-text fallback (auto-generated from HTML if null)

  // State
  active          Boolean  @default(true)
  isDefault       Boolean  @default(false)       // System-provided default template

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, eventType])          // One template per event type per org
  @@index([eventType])
}

// ─── CQRS Read Models ───────────────────────────────────────────
// Denormalized projections built from domain events.
// These tables are populated by projection handlers (OrderProjection, ShipmentProjection)
// and serve GET/list endpoints without joins.

model OrderReadModel {
  id                    String    @id                // Same as Order.id
  organization          Organization @relation(fields: [orgId], references: [id])
  orgId                 String
  orderNumber           String    @unique
  poNumber              String?
  status                String                       // pending, validated, converted, assigned, etc.
  deliveryStatus        String                       // unassigned, assigned, in_transit, delivered, exception
  customer              Customer  @relation(fields: [customerId], references: [id])
  customerId            String
  customerName          String
  originName            String?
  originCity            String?
  originState           String?
  destinationName       String?
  destinationCity       String?
  destinationState      String?
  shipment              Shipment? @relation(fields: [shipmentId], references: [id])
  shipmentId            String?
  shipmentReference     String?
  carrierName           String?
  serviceLevel          String?
  temperatureRequired   Boolean   @default(false)
  hazmat                Boolean   @default(false)
  trackableUnitCount    Int       @default(0)
  lineItemCount         Int       @default(0)
  totalWeight           Float?
  requestedDeliveryDate DateTime?
  deliveredAt           DateTime?
  exceptionType         String?
  importSource          String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([orgId])
  @@index([status])
  @@index([deliveryStatus])
  @@index([customerId])
  @@index([createdAt])
  @@index([shipmentId])
}

model ShipmentReadModel {
  id                String    @id                    // Same as Shipment.id
  organization      Organization @relation(fields: [orgId], references: [id])
  orgId             String
  reference         String    @unique
  status            String                           // draft, in_transit, delivered, etc.
  customer          Customer  @relation(fields: [customerId], references: [id])
  customerId        String
  customerName      String
  originName        String?
  originCity        String?
  originState       String?
  destinationName   String?
  destinationCity   String?
  destinationState  String?
  carrier           Carrier?  @relation(fields: [carrierId], references: [id])
  carrierId         String?
  carrierName       String?
  lane              Lane?     @relation(fields: [laneId], references: [id])
  laneId            String?
  laneName          String?
  proNumber         String?
  pickupDate        DateTime?
  deliveryDate      DateTime?
  orderCount        Int       @default(0)
  stopCount         Int       @default(0)
  currentLat        Float?
  currentLng        Float?
  lastLocationAt    DateTime?

  // Financial summary (denormalized from ShipmentFinancialSummary)
  expectedRevenueCents Int?
  expectedCostCents    Int?
  expectedMarginCents  Int?
  actualRevenueCents   Int?
  actualCostCents      Int?
  actualMarginCents    Int?

  createdAt         DateTime
  updatedAt         DateTime

  @@index([orgId])
  @@index([status])
  @@index([customerId])
  @@index([carrierId])
  @@index([createdAt])
  @@index([currentLat, currentLng])              // Composite index for map bbox queries
}

model CarrierReadModel {
  id              String    @id
  organization    Organization @relation(fields: [orgId], references: [id])
  orgId           String
  name            String
  mcNumber        String?
  dotNumber       String?
  contactEmail    String?
  status          String                           // active, archived
  validationTier  String?
  vehicleCount    Int       @default(0)
  driverCount     Int       @default(0)
  activeLaneCount Int       @default(0)
  createdAt       DateTime
  updatedAt       DateTime

  @@index([orgId])
  @@index([status])
  @@index([name])
}

model CustomerReadModel {
  id               String    @id
  organization     Organization @relation(fields: [orgId], references: [id])
  orgId            String
  name             String
  contactEmail     String?
  activeOrderCount Int       @default(0)
  totalOrderCount  Int       @default(0)
  createdAt        DateTime
  updatedAt        DateTime

  @@index([orgId])
  @@index([name])
}

model LaneReadModel {
  id                  String    @id
  organization        Organization @relation(fields: [orgId], references: [id])
  orgId               String
  name                String
  originName          String?
  originCity          String?
  destinationName     String?
  destinationCity     String?
  serviceLevel        String
  distance            Float?
  carrierCount        Int       @default(0)
  activeShipmentCount Int       @default(0)
  status              String    @default("active")
  createdAt           DateTime
  updatedAt           DateTime

  @@index([orgId])
  @@index([status])
}

// ─── Issue / Triage ─────────────────────────────────────────────
// Tracks exceptions, delays, and operational issues across the system.
// Issues can be auto-created from domain events (e.g., shipment.exception)
// or manually by dispatchers.

model Issue {
  id              String    @id @default(uuid())
  organization    Organization @relation(fields: [orgId], references: [id])
  orgId           String
  title           String
  description     String?
  status          String    @default("open")       // open, in_progress, resolved, closed
  priority        String    @default("medium")     // low, medium, high, critical
  category        String                            // exception, delay, damage, compliance, other

  // Source entity that triggered the issue
  sourceEntityType String?                          // "shipment", "order", "carrier"
  sourceEntityId   String?
  sourceEventId    String?                          // DomainEventLog.id that triggered this

  // Assignment
  assigneeId      String?
  assigneeName    String?
  escalatedTo     String?
  escalatedAt     DateTime?

  // Resolution
  resolvedAt      DateTime?
  resolvedBy      String?
  resolution      String?                           // Free-text resolution notes

  // Snooze
  snoozedUntil    DateTime?                         // null = not snoozed; set to wake time
  snoozedBy       String?
  snoozedReason   String?

  // CAPA tracking
  needsCapa       Boolean   @default(false)         // Quality team flag

  // Closure
  closedAt        DateTime?
  closedBy        String?

  // CAPA reports linked to this issue
  capaReports     CAPAReport[]

  // Labels
  labelAssignments IssueLabelAssignment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orgId])
  @@index([status])
  @@index([priority])
  @@index([sourceEntityType, sourceEntityId])
  @@index([assigneeId])
  @@index([createdAt])
  @@index([needsCapa])
  @@index([snoozedUntil])
}

model ProjectionCheckpoint {
  projectionName  String   @id
  lastEventId     String
  lastEventTime   DateTime
  processedCount  Int      @default(0)
  updatedAt       DateTime @updatedAt
}

model IssueReadModel {
  id                String    @id
  organization      Organization @relation(fields: [orgId], references: [id])
  orgId             String
  title             String
  description       String?
  status            String
  priority          String
  category          String
  sourceEntityType  String?
  sourceEntityId    String?
  sourceEventId     String?
  assigneeId        String?
  assigneeName      String?
  escalatedTo       String?
  escalatedAt       DateTime?
  resolvedAt        DateTime?
  resolution        String?
  snoozedUntil      DateTime?
  snoozedBy         String?
  needsCapa         Boolean   @default(false)
  labels            Json?                             // Cached label names: ["cold-chain", "hazmat"]
  closedAt          DateTime?
  commentCount      Int       @default(0)
  createdAt         DateTime
  updatedAt         DateTime

  @@index([orgId])
  @@index([status])
  @@index([priority])
  @@index([assigneeName])
  @@index([createdAt])
  @@index([needsCapa])
  @@index([snoozedUntil])
}

// ─── SLA (Service Level Agreements) ────────────────────────────
// Two-tier policy hierarchy: org-level defaults + customer-level overrides.
// Each policy contains typed rules covering ETA, issue response/resolution,
// dwell time, security events (light/seal), and temperature excursions.

model SlaPolicy {
  id              String    @id @default(uuid())
  orgId           String
  name            String                          // "Standard SLA", "Premium Customer SLA"
  description     String?

  // Scope: null customerId = org-wide default, non-null = customer override
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  active          Boolean   @default(true)

  rules           SlaRule[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([orgId, customerId])                   // One active policy per org or per customer
  @@index([orgId])
  @@index([customerId])
}

model SlaRule {
  id              String    @id @default(uuid())
  policy          SlaPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  policyId        String

  // Rule type discriminator
  ruleType        String                          // "eta_delivery", "issue_response", "issue_resolution",
                                                  // "dwell_time", "light_event", "seal_event",
                                                  // "temperature_excursion", "temperature_out_of_range"

  name            String                          // "Critical Issue Response Time"
  description     String?
  active          Boolean   @default(true)

  // Threshold values (interpreted based on ruleType)
  warningThresholdMinutes   Int?                  // Minutes before warning-level alert
  breachThresholdMinutes    Int?                  // Minutes before hard breach
  criticalThresholdMinutes  Int?                  // Minutes before critical escalation

  // Issue SLA filters: which priority/category does this rule apply to?
  issuePriority   String?                         // "low", "medium", "high", "critical" (null = all)
  issueCategory   String?                         // "exception", "delay", "damage", "compliance" (null = all)

  // ETA SLA: maximum allowed delivery time from pickup (minutes)
  maxDeliveryMinutes  Int?

  // Dwell time SLA
  maxDwellMinutes     Int?                        // Max minutes at a single location before alert
  dwellLocationType   String?                     // "any", "origin", "intermediate", "destination"

  // Location-type filter: restrict this rule to stops at specific facility types
  // e.g., "distribution_centre", "cross_dock", "warehouse", "terminal", "port"
  // null = applies to all location types
  locationType        String?

  // Security event SLA: allowed occurrences before breach
  maxOccurrences      Int?                        // e.g., 0 = any occurrence is a breach

  // Temperature SLA
  maxExcursionMinutes Int?                        // Max cumulative minutes out of range before breach

  // Breach action config
  autoCreateIssue       Boolean   @default(true)  // Auto-create triage issue on breach
  issuePriorityOnBreach String    @default("high") // Priority of auto-created issue

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([policyId])
  @@index([ruleType])
}

// Tracks individual SLA evaluations against shipments or issues.
// One record per (SLA rule + entity) combination.
//
// Design decision: SlaEvaluation is its own table rather than a CQRS projection
// because it is written by BOTH event handlers (instant evaluation on state changes)
// and the cron worker (periodic breach sweep). A projection is a pure read model
// derived from a single event stream — SlaEvaluation is a stateful tracking record
// with concurrent writers, so it doesn't fit that pattern.
//
// Denormalized fields (ruleName, entityReference, customerId) avoid joins on
// dashboard queries. The @@unique constraint on (ruleId, entityType, entityId)
// prevents duplicate evaluations and acts as a natural concurrency guard — if the
// cron worker and an event handler race to create the same evaluation, one will
// get a unique constraint violation and gracefully skip.

model SlaEvaluation {
  id                    String    @id @default(uuid())
  orgId                 String

  // Which SLA rule is being evaluated
  ruleId                String
  ruleType              String                    // Denormalized for querying
  ruleName              String                    // Denormalized snapshot

  // Subject of evaluation
  entityType            String                    // "shipment" or "issue"
  entityId              String
  entityReference       String?                   // Shipment reference or issue title

  // Policy context
  policyId              String
  customerId            String?                   // Denormalized for dashboard filtering

  // Timing
  slaStartedAt          DateTime                  // When the SLA clock started
  slaDueAt              DateTime?                 // When the SLA will breach
  warningAt             DateTime?                 // When warning threshold fires

  // Current state
  // Design decision: status transitions use optimistic locking via Prisma's
  // `where` clause (e.g., update where status = 'active'). This prevents race
  // conditions between the cron worker and event handlers — if both try to
  // breach the same evaluation simultaneously, only one succeeds and the other
  // gets zero affected rows, which we treat as a safe no-op.
  status                String    @default("active") // active, warning, breached, met, cancelled
  remainingMinutes      Int?

  // Breach details
  breachedAt            DateTime?
  breachDurationMinutes Int?

  // Met details
  metAt                 DateTime?

  // Auto-created issue on breach
  issueId               String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([ruleId, entityType, entityId])        // One evaluation per rule + entity
  @@index([orgId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([slaDueAt])
  @@index([customerId])
  @@index([ruleType])
}

// ============================================================
// EDI Communication Hub — Unified Trading Partner model
// ============================================================

model TradingPartner {
  id             String   @id @default(uuid())
  name           String
  active         Boolean  @default(true)

  // What kind of entity is this partner?
  entityType     String                  // "customer" | "carrier" | "3pl" | "warehouse" | "erp" | "other"
  customerId     String?                 // Optional link to Customer
  customer       Customer? @relation("CustomerTradingPartners", fields: [customerId], references: [id])
  carrierId      String?                 // Optional link to Carrier
  carrier        Carrier?  @relation("CarrierTradingPartners", fields: [carrierId], references: [id])

  // ── SFTP Connection ──
  sftpHost       String?
  sftpPort       Int      @default(22)
  sftpUsername   String?
  sftpPassword   String?
  sftpPrivateKey String?

  // ── HTTP/API Connection ──
  httpUrl        String?
  httpAuthType   String?                 // "none" | "basic" | "bearer" | "api_key"
  httpAuthHeader String?                 // Header name (e.g., "X-API-Key")
  httpAuthValue  String?                 // Auth credential value

  // ── EDI Envelope Config ──
  senderId       String?                 // ISA06 — our sender ID for this partner
  receiverId     String?                 // ISA08 — partner's receiver ID
  ediVersion     String   @default("005010")

  // ── Inbound Config ──
  inboundEnabled     Boolean  @default(false)
  inboundDir         String   @default("/")       // SFTP directory to poll for inbound files
  inboundFilePattern String   @default("*.edi,*.x12")
  pollingInterval    Int      @default(900)        // seconds (15 min default)
  pollingCron        String?                       // Optional cron expression override
  lastPolledAt       DateTime?

  // ── Outbound Config ──
  outboundEnabled    Boolean  @default(false)
  outboundDir        String?                       // SFTP directory for outbound files (null = use HTTP)
  outboundTransport  String   @default("sftp")     // "sftp" | "http"
  outboundFileNaming String   @default("reference") // "date" | "sequence" | "reference"

  // ── Legacy migration tracking ──
  migratedFromEdiPartnerId        String?           // ID of old EdiPartner if migrated
  migratedFromOutboundIntegrationId String?         // ID of old OutboundIntegration if migrated

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions   TradingPartnerTransaction[]
  ediLogs        EdiTransactionLog[]

  @@index([entityType])
  @@index([customerId])
  @@index([carrierId])
  @@index([active])
  @@index([inboundEnabled])
  @@index([outboundEnabled])
}

model TradingPartnerTransaction {
  id             String         @id @default(uuid())
  partner        TradingPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId      String

  transactionType String                  // "850" | "855" | "856" | "204" | "990" | "214" | "210" | "997" | "810"
  direction       String                  // "inbound" | "outbound"
  enabled         Boolean  @default(true)

  // Per-type config
  fieldMapping    Json?                   // Custom field mappings for this transaction type
  autoProcess     Boolean  @default(true) // Auto-create orders (850), auto-update shipments (214), etc.
  ack997Required  Boolean  @default(true) // Send/require 997 functional acknowledgment

  // Inbound file pattern override (if different from partner default)
  filePattern     String?                 // e.g., "*.990" to override partner's default "*.edi"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([partnerId, transactionType, direction])
  @@index([partnerId])
  @@index([transactionType])
  @@index([direction])
}

model EdiTransactionLog {
  id             String          @id @default(uuid())
  partner        TradingPartner? @relation(fields: [partnerId], references: [id])
  partnerId      String?

  // What was exchanged
  transactionType String                  // "850", "856", "204", "990", "997", "214", "210", "810", "820"
  direction       String                  // "inbound" | "outbound"

  // File details
  fileName        String?
  fileSize        Int?
  fileContent     String?                 // Raw EDI content (for audit)
  fileHash        String?                 // SHA-256 for dedup

  // Transport details
  transport       String    @default("api") // "sftp" | "http" | "api" | "manual"
  url             String?                 // HTTP URL or SFTP path
  responseCode    Int?                    // HTTP response code
  responseBody    String?

  // Processing
  status          String   @default("pending") // "pending" | "processing" | "success" | "error" | "duplicate"
  processedAt     DateTime?
  errorMessage    String?

  // Parse result (for inbound) — replaces EdiFile.parsedData
  parsedData      Json?
  transactionCount Int     @default(0)     // Number of transactions in file

  // Created entities tracking — replaces EdiFile.ordersCreated/orderIds
  entitiesCreated Int      @default(0)     // Orders, invoices, payments created
  entityIds       Json?                    // Array of created entity IDs
  source          String   @default("api") // "manual" | "sftp" | "api"

  // Linked entities
  shipmentId      String?
  shipmentReference String?
  orderId         String?
  tenderId        String?
  invoiceId       String?
  invoiceNumber   String?

  // 997 acknowledgment tracking
  ack997Sent      Boolean  @default(false)
  ack997Received  Boolean  @default(false)
  ack997LogId     String?                 // Reference to the 997 log entry

  // Retry
  retryCount      Int      @default(0)
  lastRetryAt     DateTime?

  createdAt       DateTime @default(now())

  @@index([partnerId])
  @@index([transactionType])
  @@index([direction])
  @@index([status])
  @@index([shipmentId])
  @@index([fileHash])
  @@index([createdAt])
  @@index([source])
}

// ============================================================
// Carrier Tendering — CarrierUser, Tender, TenderOffer, TenderBid
// ============================================================

model CarrierUser {
  id           String   @id @default(uuid())
  carrier      Carrier  @relation(fields: [carrierId], references: [id])
  carrierId    String
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("dispatcher") // "dispatcher" | "admin"
  active       Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenderBids   TenderBid[]

  @@index([carrierId])
  @@index([email])
}

model Tender {
  id                    String   @id @default(uuid())
  shipment              Shipment @relation(fields: [shipmentId], references: [id])
  shipmentId            String
  reference             String   @unique          // Auto-generated: "TND-001"

  // Strategy & configuration
  strategy              String   @default("broadcast") // "broadcast" | "waterfall"
  status                String   @default("draft")     // "draft" | "open" | "evaluating" | "awarded" | "cancelled" | "expired"
  tenderDurationMinutes Int      @default(120)         // How long carriers have to respond

  // Rate information
  targetRate            Float?                         // Target rate (what shipper hopes to pay)
  currency              String   @default("USD")

  // Shipment details for tender
  equipmentType         String?                        // "53' Dry Van", "53' Reefer", etc.
  notes                 String?
  specialInstructions   String?

  // Lifecycle timestamps
  openedAt              DateTime?
  closedAt              DateTime?
  awardedAt             DateTime?

  // Who created this tender
  createdBy             String?                        // User ID

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  offers                TenderOffer[]
  bids                  TenderBid[]

  @@index([shipmentId])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
}

model TenderOffer {
  id           String   @id @default(uuid())
  tender       Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenderId     String
  carrier      Carrier  @relation(fields: [carrierId], references: [id])
  carrierId    String

  // Waterfall sequencing (1 = first choice, 2 = second, etc.)
  sequence     Int      @default(1)

  // Status tracking
  status       String   @default("pending") // "pending" | "sent" | "viewed" | "expired" | "cancelled"
  sentAt       DateTime?
  expiresAt    DateTime?
  viewedAt     DateTime?

  // EDI 204 tracking
  ediSent      Boolean  @default(false)
  edi204Content String?                    // Stored EDI 204 document for audit trail

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bids         TenderBid[]

  @@unique([tenderId, carrierId])
  @@index([tenderId])
  @@index([carrierId])
  @@index([status])
  @@index([expiresAt])
}

model TenderBid {
  id             String      @id @default(uuid())
  tender         Tender      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenderId       String
  tenderOffer    TenderOffer @relation(fields: [tenderOfferId], references: [id], onDelete: Cascade)
  tenderOfferId  String
  carrier        Carrier     @relation(fields: [carrierId], references: [id])
  carrierId      String

  // Bid details
  rate           Float                            // Carrier's bid rate
  currency       String      @default("USD")
  transitDays    Int?                             // Estimated transit time in days
  equipmentType  String?                          // Equipment offered
  notes          String?                          // Carrier comments

  // Status
  status         String      @default("submitted") // "submitted" | "accepted" | "rejected" | "withdrawn" | "expired"
  submittedAt    DateTime    @default(now())
  respondedAt    DateTime?                        // When the bid was accepted/rejected

  // Who submitted this bid
  submittedBy    CarrierUser? @relation(fields: [submittedById], references: [id])
  submittedById  String?                          // Null if submitted via EDI

  // Source tracking
  sourceType     String      @default("portal")  // "portal" | "edi_990" | "manual"
  edi990Content  String?                          // Raw EDI 990 content if submitted via EDI

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([tenderOfferId, carrierId])
  @@index([tenderId])
  @@index([carrierId])
  @@index([status])
  @@index([submittedAt])
}

// ============================================================
// IoT Device Tracking
// ============================================================

model Device {
  id              String    @id @default(uuid())
  externalId      String    @unique               // Provider device ID (e.g., System Loco ObjectId)
  displayId       String?                         // User-friendly ID (e.g., "HG-00012345")
  name            String                          // Device name — used for shipment/order matching
  provider        String    @default("system_loco")
  model           String?                         // Device model (e.g., "HGx")
  manufacturer    String?                         // Device manufacturer (e.g., "System Loco")
  firmware        String?
  labels          Json?                           // string[] of device tags/labels
  status          String    @default("active")    // active, inactive, retired
  batteryLevel    Int?
  lastSeenAt      DateTime?
  lastLat         Float?
  lastLng         Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments     DeviceAssignment[]
  sensorReadings  SensorReading[]
  deviceEvents    DeviceEvent[]
  calibrations    DeviceCalibration[]
  temperatureLogs ImmutableTemperatureLog[]
  coldChainExcursions ColdChainExcursion[]

  @@index([name])
  @@index([provider])
  @@index([status])
}

model DeviceAssignment {
  id              String    @id @default(uuid())
  device          Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId        String
  shipment        Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  shipmentId      String?
  order           Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId         String?
  trackableUnitId String?
  active          Boolean   @default(true)
  assignedAt      DateTime  @default(now())
  unassignedAt    DateTime?

  @@index([deviceId, active])
  @@index([shipmentId])
  @@index([orderId])
}

model SensorReading {
  id              String    @id @default(uuid())
  device          Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId        String
  shipment        Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  shipmentId      String?
  order           Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId         String?
  trackableUnit   TrackableUnit? @relation(fields: [trackableUnitId], references: [id], onDelete: SetNull)
  trackableUnitId String?
  eventTime       DateTime                        // When the reading occurred

  // Sensor values (nullable — only populated when present)
  temperature     Float?
  humidity        Float?
  lightLevel      Int?
  batteryLevel    Int?
  batteryVoltage  Float?
  impactG         Float?
  tiltAngle       Float?
  movement        String?                         // "stationary" | "moving"

  // Location at time of reading
  lat             Float?
  lng             Float?
  address         String?

  // Thresholds (from device config, for context)
  tempMin         Float?
  tempMax         Float?
  lightMin        Int?
  lightMax        Int?

  // Alert
  isAlert         Boolean   @default(false)
  alertType       String?                         // "temperature" | "impact" | "light" | "tip" | "battery"

  rawPayload      Json?
  createdAt       DateTime  @default(now())

  @@index([deviceId, eventTime])
  @@index([shipmentId, eventTime])
  @@index([orderId, eventTime])
  @@index([trackableUnitId, eventTime])
  @@index([isAlert])
}

model DeviceEvent {
  id              String    @id @default(uuid())
  device          Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId        String
  shipmentId      String?
  orderId         String?
  trackableUnit   TrackableUnit? @relation(fields: [trackableUnitId], references: [id], onDelete: SetNull)
  trackableUnitId String?

  externalEventId String?   @unique               // System Loco event ID (for dedup)
  eventType       String                          // temperature, impact, drop, tip, zoneChange, firmware, charging, etc.
  category        String                          // "event" | "warning" | "info"

  startTime       DateTime
  endTime         DateTime?

  lat             Float?
  lng             Float?
  address         String?
  zoneName        String?

  message         String?
  payload         Json?                           // Full type-specific payload

  createdAt       DateTime  @default(now())

  @@index([deviceId, startTime])
  @@index([shipmentId])
  @@index([eventType])
}

// ============================================================
// Cargo Tracking & Misdrop Detection
// ============================================================

// Records physical confirmation of a trackable unit at a specific stop
model CargoScan {
  id                String        @id @default(uuid())
  trackableUnit     TrackableUnit @relation(fields: [trackableUnitId], references: [id], onDelete: Cascade)
  trackableUnitId   String
  shipmentStop      ShipmentStop  @relation(fields: [shipmentStopId], references: [id], onDelete: Cascade)
  shipmentStopId    String
  shipment          Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId        String

  // Scan details
  scanType          String        // load, unload, checkpoint
  scanMethod        String        // barcode, rfid, manual, geofence, iot
  scannedAt         DateTime      @default(now())
  scannedBy         String?       // User ID or device ID

  // Location at scan time
  lat               Float?
  lng               Float?

  // Result of scan evaluation
  expected          Boolean       @default(true) // Was this unit expected at this stop?
  notes             String?

  createdAt         DateTime      @default(now())

  @@index([trackableUnitId])
  @@index([shipmentStopId])
  @@index([shipmentId])
  @@index([scannedAt])
}

// Tracks cargo discrepancies — misdrops, missing cargo, unexpected deliveries
model CargoDiscrepancy {
  id                String        @id @default(uuid())
  shipment          Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId        String
  trackableUnit     TrackableUnit @relation(fields: [trackableUnitId], references: [id], onDelete: Cascade)
  trackableUnitId   String

  // Discrepancy classification
  discrepancyType   String        // misdrop_early, misdrop_late, missing_at_stop, unexpected_at_stop, left_on_vehicle, damaged, wrong_destination
  severity          String        @default("high") // critical, high, medium, low

  // Where was it supposed to go vs where it actually went
  expectedStop      ShipmentStop? @relation("ExpectedStop", fields: [expectedStopId], references: [id])
  expectedStopId    String?
  actualStop        ShipmentStop? @relation("ActualStop", fields: [actualStopId], references: [id])
  actualStopId      String?

  // Lifecycle
  status            String        @default("open") // open, investigating, resolved, dismissed
  detectedAt        DateTime      @default(now())
  detectedBy        String        @default("system") // system, manual, driver, iot
  resolvedAt        DateTime?
  resolvedBy        String?
  resolution        String?       // Description of how it was resolved

  // Context
  description       String        // Human-readable description of the issue
  notes             String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([shipmentId])
  @@index([trackableUnitId])
  @@index([status])
  @@index([discrepancyType])
  @@index([detectedAt])
}

// ============================================================
// Cold Chain & Compliance
// ============================================================

// Named temperature/humidity profile — e.g. "Frozen Goods (-25°C to -18°C)"
model ColdChainProfile {
  id                  String    @id @default(uuid())
  orgId               String
  name                String                          // e.g. "Frozen Goods", "Refrigerated Pharma"
  description         String?

  // Acceptable temperature range (°C — canonical metric)
  minTemperature      Float                           // Lower acceptable limit
  maxTemperature      Float                           // Upper acceptable limit

  // Alert thresholds — tighter than acceptable range, triggers warning before breach
  alertMinTemperature Float                           // Lower warning threshold
  alertMaxTemperature Float                           // Upper warning threshold

  // Optional humidity range (% RH)
  minHumidity         Float?
  maxHumidity         Float?
  alertMinHumidity    Float?
  alertMaxHumidity    Float?

  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  createdBy           String?                         // User ID who created
  updatedBy           String?                         // User ID who last modified

  shipments           Shipment[]

  @@index([orgId])
  @@index([active])
}

// Device calibration records — tracks whether temperature sensors are signed off
model DeviceCalibration {
  id                  String    @id @default(uuid())
  orgId               String
  device              Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId            String

  calibratedAt        DateTime                        // When calibration was performed
  calibratedBy        String                          // Person or lab that performed calibration
  certificateNumber   String?                         // Calibration certificate reference
  expiresAt           DateTime                        // When calibration expires
  calibrationMethod   String?                         // Method used (e.g., "NIST traceable", "2-point")
  accuracy            Float?                          // Accuracy in °C (e.g., 0.5 means ±0.5°C)
  status              String    @default("valid")     // valid, expired, pending
  notes               String?

  // Optional link to calibration certificate document
  documentStorageKey  String?                         // Storage key for certificate PDF

  createdAt           DateTime  @default(now())
  createdBy           String?                         // User ID who recorded this

  @@index([deviceId])
  @@index([orgId])
  @@index([status])
  @@index([expiresAt])
}

// Immutable temperature log — WRITE-ONLY. No updates or deletes. CFR 21 Part 11 compliant.
// Each row is a tamper-evident record of a temperature reading with a snapshot of the active profile thresholds.
model ImmutableTemperatureLog {
  id                  String    @id @default(uuid())
  orgId               String

  // Links to entities
  shipment            Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  shipmentId          String?
  device              Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  deviceId            String?
  orderId             String?
  trackableUnitId     String?

  // Sensor values
  temperature         Float                           // °C — canonical metric
  humidity            Float?                          // % RH

  // Location at time of reading
  lat                 Float?
  lng                 Float?

  // Timestamps
  recordedAt          DateTime                        // When the device captured the reading
  capturedAt          DateTime  @default(now())       // When the system received it

  // Profile thresholds at time of capture — snapshot for audit trail
  profileMinTemp      Float?
  profileMaxTemp      Float?
  profileAlertMinTemp Float?
  profileAlertMaxTemp Float?
  profileName         String?                         // Name of profile at time of capture

  // Compliance flags
  isWithinRange       Boolean                         // temperature within [profileMinTemp, profileMaxTemp]
  isWithinAlertRange  Boolean                         // temperature within [profileAlertMinTemp, profileAlertMaxTemp]
  isExcursion         Boolean   @default(false)       // Outside acceptable range
  isAlert             Boolean   @default(false)       // Outside alert range but within acceptable

  // Tamper evidence — SHA-256 hash of (shipmentId + deviceId + temperature + recordedAt + profileMinTemp + profileMaxTemp)
  integrityHash       String

  // Original raw payload for forensic analysis
  rawPayload          Json?

  // Immutable: createdAt only, no updatedAt
  createdAt           DateTime  @default(now())

  @@index([shipmentId, recordedAt])
  @@index([deviceId, recordedAt])
  @@index([orgId, capturedAt])
  @@index([isExcursion])
  @@index([isAlert])
}

// Temperature excursion — a period where readings breached profile thresholds
model ColdChainExcursion {
  id                  String    @id @default(uuid())
  orgId               String

  shipment            Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId          String
  device              Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  deviceId            String?

  // Excursion classification
  excursionType       String                          // high_temp, low_temp, high_humidity, low_humidity
  severity            String                          // warning (alert range), critical (acceptable range breach)

  // Duration
  startedAt           DateTime                        // First reading outside threshold
  endedAt             DateTime?                       // Last reading outside threshold (null if ongoing)
  durationMinutes     Int?                            // Computed duration

  // Worst-case values
  peakValue           Float                           // Worst reading during excursion
  thresholdValue      Float                           // What was the limit that was breached

  readingCount        Int       @default(1)           // How many readings fell within this excursion

  // Lifecycle
  status              String    @default("active")    // active, acknowledged, resolved
  acknowledgedBy      String?
  acknowledgedAt      DateTime?
  resolvedBy          String?
  resolvedAt          DateTime?

  // Disposition decision
  dispositionDecision String?                         // released, quarantined
  notes               String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shipmentId])
  @@index([orgId])
  @@index([status])
  @@index([severity])
  @@index([startedAt])
}

// CAPA Report — Corrective and Preventive Action, linked to Issues in Triage
model CAPAReport {
  id                  String    @id @default(uuid())
  orgId               String

  // Links
  issue               Issue     @relation(fields: [issueId], references: [id])
  issueId             String
  shipment            Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  shipmentId          String?

  // Identification
  reportNumber        String                          // Auto-generated: CAPA-YYYYMMDD-NNN
  title               String
  status              String    @default("draft")     // draft, investigation, root_cause_identified, action_plan, implementation, verification, closed
  priority            String    @default("medium")    // low, medium, high, critical

  // Problem description
  description         String                          // What happened
  immediateAction     String?                         // What was done immediately
  containmentAction   String?                         // Steps taken to prevent further impact

  // Investigation
  investigationDetails String?
  rootCause           String?
  rootCauseCategory   String?                         // equipment, process, personnel, environmental, material, other

  // Corrective action
  correctiveAction    String?
  correctiveActionDueDate DateTime?
  correctiveActionCompletedDate DateTime?

  // Preventive action
  preventiveAction    String?
  preventiveActionDueDate DateTime?
  preventiveActionCompletedDate DateTime?

  // People
  investigatorId      String?                         // User ID of investigator
  investigatorName    String?
  approverId          String?                         // User ID of approver
  approverName        String?
  approvedAt          DateTime?

  // Affected scope
  affectedProducts    Json?                           // string[] of product descriptions
  affectedShipmentIds Json?                           // string[] of shipment IDs
  affectedLocationIds Json?                           // string[] of location IDs

  // Context snapshots
  eventTimeline       Json?                           // Key events leading to the issue
  temperatureData     Json?                           // Summary of temp readings during incident

  // Verification & closure
  verificationMethod  String?
  verifiedById        String?
  verifiedByName      String?
  verifiedAt          DateTime?
  effectivenessCheck  String?
  lessonsLearned      String?

  // Follow-up notes (30/60/90 day reviews)
  followUps           CAPAFollowUp[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  createdBy           String?
  updatedBy           String?

  @@index([orgId])
  @@index([issueId])
  @@index([shipmentId])
  @@index([status])
  @@index([reportNumber])
}

// ─── Warehouse App: Magic Links ─────────────────────────────────────────────

model MagicLink {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  tokenHash   String    @unique  // SHA-256 hash of the magic link token
  expiresAt   DateTime?          // Null = never expires (persistent QR code)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

// ─── Warehouse App: Login Audit Log ─────────────────────────────────────────

model LoginAuditLog {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  method      String    // "password", "magic_link", "oauth_google", "oauth_microsoft"
  ipAddress   String?
  userAgent   String?
  success     Boolean   @default(true)
  failReason  String?   // "invalid_password", "locked", "expired_link", etc.
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([method])
}

// ─── Warehouse App: Shipment Accessories ────────────────────────────────────

model ShipmentAccessory {
  id            String    @id @default(uuid())
  shipment      Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId    String
  accessoryType String    // "door_seal", "temp_sensor_front", "temp_sensor_middle", "temp_sensor_back", "door_sensor", "ble_tracker"
  alias         String?   // User-friendly label
