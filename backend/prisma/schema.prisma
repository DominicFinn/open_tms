generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id           String   @id @default(uuid())
  name         String
  contactEmail String?
  archived     Boolean  @default(false)
  archivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shipments    Shipment[]
  customerLanes CustomerLane[]
  orders       Order[]
  apiKeys      ApiKey[]
  ediPartners  EdiPartner[]
  users        User[]

  // Custom fields
  customFieldVersionId String?              // Version of custom field definitions used
  customFieldValues    Json?                // { "fieldKey": value, ... }
}

model Location {
  id         String   @id @default(uuid())
  name       String
  address1   String
  address2   String?
  city       String
  state      String?
  postalCode String?
  country    String
  lat        Float?
  lng        Float?
  archived   Boolean  @default(false)
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  originFor  Shipment[] @relation("Origin")
  destFor    Shipment[] @relation("Destination")
  lanesAsOrigin Lane[] @relation("LaneOrigin")
  lanesAsDestination Lane[] @relation("LaneDestination")
  laneStops  LaneStop[]
  orderOriginFor Order[] @relation("OrderOrigin")
  orderDestFor   Order[] @relation("OrderDestination")
  pendingLaneRequestsAsOrigin PendingLaneRequest[] @relation("PendingLaneOrigin")
  pendingLaneRequestsAsDestination PendingLaneRequest[] @relation("PendingLaneDestination")
  shipmentStops  ShipmentStop[] // Multi-stop shipment support

  // Custom fields
  customFieldVersionId String?
  customFieldValues    Json?
}

model Shipment {
  id            String   @id @default(uuid())
  reference     String
  status        String   @default("draft")
  pickupDate    DateTime?
  deliveryDate  DateTime?
  items         Json?
  archived      Boolean  @default(false)
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id])
  customerId    String
  origin        Location @relation("Origin", fields: [originId], references: [id])
  originId      String
  destination   Location @relation("Destination", fields: [destinationId], references: [id])
  destinationId String
  lane          Lane?    @relation(fields: [laneId], references: [id])
  laneId        String?
  carrier       Carrier? @relation(fields: [carrierId], references: [id])
  carrierId     String?  // Manual carrier assignment for non-lane shipments
  loads         Load[]
  events        ShipmentEvent[]
  orderShipments OrderShipment[]
  stops         ShipmentStop[] // Multi-stop route support
  outboundLogs  OutboundIntegrationLog[] // Outbound integration logs

  // Custom fields
  customFieldVersionId String?
  customFieldValues    Json?
}

model ShipmentStop {
  id                String    @id @default(uuid())
  shipment          Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId        String
  location          Location  @relation(fields: [locationId], references: [id])
  locationId        String

  // Stop sequence in the route (1 = first stop, 2 = second, etc.)
  sequenceNumber    Int

  // Type of stop
  stopType          String    @default("delivery") // pickup, delivery, both

  // Timing
  estimatedArrival  DateTime?
  actualArrival     DateTime?
  estimatedDeparture DateTime?
  actualDeparture   DateTime?

  // Status
  status            String    @default("pending") // pending, arrived, in_progress, completed, skipped

  // Orders to be delivered at this stop
  orders            Order[]

  // Geofencing (for automatic status updates)
  geofenceRadius    Float?    // Radius in meters for geofence trigger
  geofenceEnabled   Boolean   @default(false)

  // Notes and instructions
  notes             String?
  instructions      String?   // Specific delivery instructions for this stop

  // Proof of delivery
  signatureUrl      String?   // URL to signature image
  photoUrls         Json?     // Array of photo URLs
  proofOfDelivery   Json?     // Additional proof data

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([shipmentId, sequenceNumber])
  @@index([shipmentId])
  @@index([locationId])
  @@index([status])
}

model ShipmentEvent {
  id              String   @id @default(uuid())
  shipment        Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId      String
  eventType       String   // "location", "status_change", "note", etc.
  deviceId        String?  // External device ID (e.g., "72308628872889491")
  deviceName      String?  // Device display name (e.g., "SH-0001")
  lat             Float?   // Latitude from GPS
  lng             Float?   // Longitude from GPS
  address         String?  // Human-readable address
  locationSummary String?  // Full location summary from webhook
  rawPayload      Json?    // Store the entire webhook payload for debugging
  eventTime       DateTime // When the event occurred (from webhook)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shipmentId])
  @@index([eventTime])
}

model Carrier {
  id           String   @id @default(uuid())
  name         String
  mcNumber     String?
  dotNumber    String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  address1     String?
  address2     String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  archived     Boolean  @default(false)
  archivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  vehicles     Vehicle[]
  drivers      Driver[]
  laneCarriers LaneCarrier[]
  shipments    Shipment[]

  // Custom fields
  customFieldVersionId String?
  customFieldValues    Json?
}

model Vehicle {
  id         String   @id @default(uuid())
  carrier    Carrier  @relation(fields: [carrierId], references: [id])
  carrierId  String
  plate      String
  type       String
  capacityKg Int?
  capacityM3 Int?
  loads      Load[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Driver {
  id        String   @id @default(uuid())
  carrier   Carrier  @relation(fields: [carrierId], references: [id])
  carrierId String
  name      String
  phone     String?
  email     String?
  loads     Load[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Load {
  id         String   @id @default(uuid())
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
  shipmentId String
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId  String?
  driver     Driver?  @relation(fields: [driverId], references: [id])
  driverId   String?
  assignedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lane {
  id            String   @id @default(uuid())
  name          String   // Auto-generated: "Origin → Destination"
  origin        Location @relation("LaneOrigin", fields: [originId], references: [id])
  originId      String
  destination   Location @relation("LaneDestination", fields: [destinationId], references: [id])
  destinationId String
  distance      Float?   // Optional distance in km
  notes         String?

  // Lane capabilities for order matching
  serviceLevel          String    @default("LTL") // "FTL", "LTL", or "Both"
  supportsTemperatureControl Boolean @default(false) // Can handle refrigerated/frozen
  supportsHazmat        Boolean   @default(false) // Hazmat certified
  maxWeight             Float?    // Maximum weight capacity in kg
  maxVolume             Float?    // Maximum volume capacity in m³

  status        String   @default("active") // active/archived
  archived      Boolean  @default(false)
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  shipments     Shipment[]
  customerLanes CustomerLane[]
  laneCarriers  LaneCarrier[]
  stops         LaneStop[]
}

model CustomerLane {
  id         String   @id @default(uuid())
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String
  lane       Lane     @relation(fields: [laneId], references: [id])
  laneId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, laneId])
}

model LaneCarrier {
  id           String   @id @default(uuid())
  lane         Lane     @relation(fields: [laneId], references: [id])
  laneId       String
  carrier      Carrier  @relation(fields: [carrierId], references: [id])
  carrierId    String
  price        Float?   // Price per shipment or per km
  currency     String   @default("USD")
  serviceLevel String?  // e.g., "Standard", "Express", "Economy"
  notes        String?
  assigned     Boolean  @default(false) // True if this carrier is assigned to the lane
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([laneId, carrierId])
}

model LaneStop {
  id         String   @id @default(uuid())
  lane       Lane     @relation(fields: [laneId], references: [id], onDelete: Cascade)
  laneId     String
  location   Location @relation(fields: [locationId], references: [id])
  locationId String
  order      Int      // Order of the stop in the lane (1, 2, 3, etc.)
  notes      String?  // Optional notes for this specific stop
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([laneId, order])
  @@unique([laneId, locationId])
}

model Order {
  id                    String   @id @default(uuid())
  orderNumber           String   @unique // Customer's order number or our generated number
  poNumber              String?  // Purchase order number
  status                String   @default("pending") // pending, validated, location_error, converted, cancelled, archived
  importSource          String   @default("manual") // manual, csv, edi
  ediData               Json?    // Store original EDI data if imported via EDI

  customer              Customer @relation(fields: [customerId], references: [id])
  customerId            String

  // Origin and destination - nullable because location might not exist yet
  origin                Location? @relation("OrderOrigin", fields: [originId], references: [id])
  originId              String?
  originData            Json?     // Store raw location data if location doesn't exist
  originValidated       Boolean   @default(false)

  destination           Location? @relation("OrderDestination", fields: [destinationId], references: [id])
  destinationId         String?
  destinationData       Json?     // Store raw location data if location doesn't exist
  destinationValidated  Boolean   @default(false)

  // Dates
  orderDate             DateTime  @default(now())
  requestedPickupDate   DateTime?
  requestedDeliveryDate DateTime?

  // Special requirements for shipment assignment
  serviceLevel          String    @default("LTL") // "FTL" (Full Truck Load) or "LTL" (Less Than Truck Load)
  temperatureControl    String    @default("ambient") // "ambient", "refrigerated", "frozen"
  requiresHazmat        Boolean   @default(false)
  specialRequirements   Json?     // Additional requirements as JSON array

  // Delivery status tracking (separate from order lifecycle status)
  deliveryStatus        String    @default("unassigned") // unassigned, assigned, in_transit, delivered, exception, cancelled
  deliveredAt           DateTime? // When the order was delivered
  deliveryConfirmedBy   String?   // User ID or system identifier who confirmed delivery
  deliveryMethod        String?   // manual, geofence, geofence_iot, auto, driver_app
  deliveryNotes         String?   // Notes about the delivery
  exceptionType         String?   // If exception status: delay, damage, refused, address_issue, weather, other
  exceptionNotes        String?   // Details about the exception
  exceptionResolvedAt   DateTime? // When the exception was resolved

  // Link to the specific stop where this order should be delivered (for multi-stop shipments)
  deliveryStop          ShipmentStop? @relation(fields: [deliveryStopId], references: [id])
  deliveryStopId        String?

  // Trackable units (pallets, totes, boxes, etc.)
  trackableUnits        TrackableUnit[]

  // Line items (legacy - will be moved to trackable units)
  lineItems             OrderLineItem[]

  // Additional info
  specialInstructions   String?
  notes                 String?

  // Tracking
  archived              Boolean   @default(false)
  archivedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relationship to shipments
  orderShipments        OrderShipment[]

  // Audit trail
  auditLogs             AuditLog[]

  // Pending lane requests
  pendingLaneRequests   PendingLaneRequest[]

  // Custom fields
  customFieldVersionId String?
  customFieldValues    Json?
}

model OrderLineItem {
  id          String  @id @default(uuid())
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String

  // Optional: which trackable unit does this item belong to?
  trackableUnit   TrackableUnit? @relation(fields: [trackableUnitId], references: [id], onDelete: Cascade)
  trackableUnitId String?

  sku         String
  description String?
  quantity    Int
  weight      Float?  // in kg
  weightUnit  String  @default("kg")
  length      Float?  // dimensions in cm
  width       Float?
  height      Float?
  dimUnit     String  @default("cm")

  // Additional fields
  hazmat      Boolean @default(false)
  temperature String? // e.g., "ambient", "refrigerated", "frozen"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrderShipment {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  shipment    Shipment @relation(fields: [shipmentId], references: [id])
  shipmentId  String
  createdAt   DateTime @default(now())

  @@unique([orderId, shipmentId])
}

model Organization {
  id                  String   @id @default(uuid())
  name                String   @default("Default Organization")

  // Lowest Trackable Unit Configuration
  trackingMode        String   @default("item") // "group" or "item"
  trackableUnitType   String   @default("box") // "pallet", "tote", "box", "stillage", "custom"
  customUnitName      String?  // Used when trackableUnitType is "custom"

  // Unit of Measure Configuration (system-level defaults)
  weightUnit          String   @default("kg")   // "kg" or "lb"
  dimUnit             String   @default("cm")   // "cm" or "in"
  temperatureUnit     String   @default("C")    // "C" or "F"
  distanceUnit        String   @default("km")   // "km" or "mi"

  // BOL sequence counter for auto-numbering
  bolSequenceNumber   Int      @default(0)

  // Metadata
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users               User[]
}

model TrackableUnit {
  id              String   @id @default(uuid())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String

  // Unit identification
  identifier      String   // e.g., "PALLET-001", "BOX-123", user-defined identifier
  unitType        String   // Snapshot of the org setting at creation time (pallet, tote, box, stillage, custom)
  customTypeName  String?  // If custom type was used

  // Sequence number within the order
  sequenceNumber  Int      // 1, 2, 3... for ordering within an order

  // Line items contained in this unit
  lineItems       OrderLineItem[]

  // Additional tracking
  barcode         String?  // Optional barcode/QR code
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orderId, sequenceNumber])
  @@index([orderId])
}

model AuditLog {
  id          String   @id @default(uuid())

  // Entity tracking
  entityType  String   // "order", "trackable_unit", "line_item"
  entityId    String   // ID of the affected entity
  orderId     String?  // Reference to order for easy filtering
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Action details
  action      String   // "created", "updated", "deleted", "converted", "moved", etc.
  description String   // Human-readable description
  changes     Json?    // JSON object with before/after values

  // User tracking
  user        User?    @relation("AuditUser", fields: [userId], references: [id])
  userId      String?  // User who performed the action
  userName    String?  // Name of the user (denormalized for display)

  // Metadata
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PendingLaneRequest {
  id          String   @id @default(uuid())

  // Order that triggered this request
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String

  // Lane details needed
  originId      String
  origin        Location @relation("PendingLaneOrigin", fields: [originId], references: [id])
  destinationId String
  destination   Location @relation("PendingLaneDestination", fields: [destinationId], references: [id])

  // Required capabilities
  serviceLevel          String   // "FTL" or "LTL"
  requiresTemperatureControl Boolean @default(false)
  requiresHazmat        Boolean  @default(false)

  // Status tracking
  status        String   @default("pending") // "pending", "approved", "rejected", "lane_created"
  resolvedAt    DateTime?
  resolvedById  String?  // User who resolved this request
  createdLaneId String?  // If approved and lane was created

  // Notes
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([originId, destinationId])
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String   // User-friendly name for the API key
  keyHash     String   @unique // Hashed version of the API key
  keyPrefix   String   // First 8 characters for display (e.g., "sk_live_...")
  active      Boolean  @default(true)
  customer    Customer? @relation(fields: [customerId], references: [id])
  customerId  String?   // Links API key to a specific customer for scoped access
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  webhookLogs WebhookLog[]

  @@index([active])
  @@index([createdAt])
  @@index([customerId])
}

model WebhookLog {
  id                String   @id @default(uuid())
  apiKey            ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  apiKeyId          String?
  
  // Request details
  method            String   // HTTP method (POST, etc.)
  path              String?
  ipAddress         String?
  userAgent         String?
  headers           Json?    // Request headers (redacted API key)
  
  // Payload details
  deviceName        String?  // Extracted device name from payload
  deviceId          String?  // Device ID from payload
  eventType         String?  // Event type (location, etc.)
  hasLocation       Boolean  @default(false) // Whether lat/lng were provided
  lat               Float?
  lng               Float?
  rawPayload        Json?    // Full request body
  
  // Processing results
  status            String   // "success", "error", "skipped", "not_found"
  shipmentFound     Boolean  @default(false)
  shipmentUpdated   Boolean  @default(false)
  shipmentId        String?  // ID of shipment if found
  shipmentReference String?  // Reference of shipment if found
  shipmentEventId   String?  // ID of created ShipmentEvent if any
  errorMessage      String?  // Error message if status is "error"
  
  // Response
  responseCode      Int?     // HTTP response code
  responseBody      Json?    // Response body sent back
  
  // Timestamps
  receivedAt        DateTime @default(now())
  processedAt       DateTime?
  
  @@index([apiKeyId])
  @@index([status])
  @@index([shipmentId])
  @@index([receivedAt])
  @@index([deviceName])
}

model OutboundIntegration {
  id          String   @id @default(uuid())
  name        String   // User-friendly name
  url         String   // URL to send EDI 856 to
  active      Boolean  @default(true)
  description String?  // Optional description
  
  // EDI Configuration
  senderId     String?  // ISA06 - Sender ID
  receiverId  String?  // ISA08 - Receiver ID
  interchangeControlNumber String? // ISA13 - Control number prefix
  
  // Integration type and format
  integrationType  String   @default("carrier")  // "carrier" | "tracking"
  payloadFormat    String   @default("edi_856")   // "edi_856" | "json"
  carrierMatch     String?  // Carrier name pattern to match (e.g., "FedEx*")

  // Authentication (optional)
  authType    String?  // "none", "basic", "bearer", "api_key"
  authHeader  String?  // Header name for auth (e.g., "X-API-Key")
  authValue   String?  // Encrypted/hashed auth value

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        OutboundIntegrationLog[]

  @@index([active])
  @@index([active, integrationType])
  @@index([createdAt])
}

model OutboundIntegrationLog {
  id                String   @id @default(uuid())
  integration       OutboundIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  integrationId     String
  
  // Shipment details
  shipment          Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  shipmentId        String?
  shipmentReference String?  // For easier filtering
  
  // Request details
  url               String
  method            String   @default("POST")
  headers           Json?    // Request headers (redacted auth)
  ediPayload        String?  // The EDI 856 document sent
  payloadSize       Int?     // Size in bytes
  
  // Response details
  status            String   // "success", "error", "pending"
  responseCode      Int?
  responseBody      String?  // Response body received
  responseHeaders   Json?    // Response headers
  errorMessage      String?  // Error message if failed
  
  // Retry information
  retryCount        Int      @default(0)
  lastRetryAt       DateTime?
  
  // Timestamps
  sentAt            DateTime @default(now())
  respondedAt       DateTime?
  
  @@index([integrationId])
  @@index([shipmentId])
  @@index([shipmentReference])
  @@index([status])
  @@index([sentAt])
}

model EdiPartner {
  id              String   @id @default(uuid())
  name            String
  active          Boolean  @default(true)

  // Link to customer
  customer        Customer @relation(fields: [customerId], references: [id])
  customerId      String

  // SFTP Configuration
  sftpHost        String?
  sftpPort        Int      @default(22)
  sftpUsername     String?
  sftpPassword    String?
  sftpPrivateKey  String?
  sftpRemoteDir   String   @default("/")
  sftpFilePattern String   @default("*.edi,*.x12,*.850")

  // Polling schedule
  pollingEnabled  Boolean  @default(false)
  pollingInterval Int      @default(900) // seconds (15 min default)
  pollingCron     String?
  lastPolledAt    DateTime?

  // EDI Configuration
  senderId        String?
  receiverId      String?
  ediVersion      String   @default("005010")

  // Processing options
  autoCreateOrders    Boolean @default(true)
  autoAssignShipments Boolean @default(false)

  // Field mapping template (JSON)
  fieldMapping    Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ediFiles        EdiFile[]

  @@index([customerId])
  @@index([active])
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String?  // Null for OAuth-only users
  firstName      String
  lastName       String
  active         Boolean  @default(true)

  // OAuth provider (null = local password auth)
  authProvider   String?  // "google", "microsoft", or null for local
  authProviderId String?  // External user ID from the OAuth provider

  // Organization
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  // Optional link to customer (for customer-portal users)
  customer       Customer? @relation(fields: [customerId], references: [id])
  customerId     String?

  // Profile
  avatarUrl      String?
  phone          String?
  timezone       String   @default("UTC")

  // Unit of measure preferences (null = use organization default)
  weightUnit     String?                    // "kg" or "lb"
  dimUnit        String?                    // "cm" or "in"
  temperatureUnit String?                   // "C" or "F"
  distanceUnit   String?                    // "km" or "mi"

  // Auth metadata
  lastLoginAt    DateTime?
  passwordChangedAt DateTime?
  failedLoginAttempts Int  @default(0)
  lockedUntil    DateTime?

  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationships
  roles          UserRole[]
  sessions       Session[]
  auditLogs      AuditLog[] @relation("AuditUser")

  @@index([email])
  @@index([organizationId])
  @@index([customerId])
  @@index([active])
  @@unique([authProvider, authProviderId])
}

model AuthProvider {
  id           String   @id @default(uuid())
  provider     String   @unique // "google", "microsoft"
  displayName  String   // "Google", "Microsoft"
  enabled      Boolean  @default(false)

  // OAuth credentials (set by admin)
  clientId     String?
  clientSecret String?

  // Provider-specific config
  tenantId     String?  // Microsoft: Azure AD tenant ID (blank = common)
  allowedDomains Json?  // Optional: restrict to specific email domains e.g. ["company.com"]

  // Auto-provisioning
  autoCreateUsers   Boolean @default(true)  // Create user on first OAuth login
  defaultRoleId     String? // Role to assign to auto-created users

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // admin, dispatcher, warehouse, readonly, customer
  description String?
  permissions Json     // Array of permission strings e.g. ["shipments:read", "shipments:write", "orders:*"]
  isSystem    Boolean  @default(false) // System roles can't be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
}

model UserRole {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    String
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Session {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  tokenHash    String   @unique // SHA-256 hash of the refresh token
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── EDI Models ──────────────────────────────────────────────────────────────

model EdiFile {
  id              String   @id @default(uuid())

  // Link to partner (optional — manual uploads won't have one)
  partner         EdiPartner? @relation(fields: [partnerId], references: [id])
  partnerId       String?

  // File metadata
  fileName        String
  fileSize        Int?
  fileContent     String   // Raw EDI content (database storage adapter)
  fileHash        String?  // SHA-256 for dedup

  // Source tracking
  source          String   @default("manual") // manual, sftp, api

  // Processing status
  status          String   @default("pending") // pending, processing, completed, failed, duplicate
  processedAt     DateTime?
  errorMessage    String?

  // Parsing results
  parsedData      Json?
  transactionType String?
  transactionCount Int     @default(0)

  // Orders created from this file
  ordersCreated   Int      @default(0)
  orderIds        Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([partnerId])
  @@index([status])
  @@index([fileHash])
  @@index([createdAt])
}

// ─── Binary Storage (fallback when S3 not configured) ───────────────────────

model BinaryStore {
  key       String   @id       // S3-style key path e.g. "attachments/shipment/abc/file.pdf"
  content   Bytes
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Attachment Models ──────────────────────────────────────────────────────

model Attachment {
  id              String   @id @default(uuid())
  entityType      String                        // "shipment", "order", "carrier", "customer", "location"
  entityId        String
  fileName        String                        // Original filename (for Content-Disposition only)
  mimeType        String
  fileSize        Int
  storageKey      String                        // Opaque UUID-based key — no entity info or filenames
  storageBackend  String   @default("s3")       // "s3" or "database"
  uploadedBy      String?                       // userId
  description     String?
  retentionExpiresAt DateTime?                  // Default: 10 years from creation. Null = indefinite.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([retentionExpiresAt])
}

// ─── Document Models ────────────────────────────────────────────────────────

model DocumentTemplate {
  id              String   @id @default(uuid())
  name            String                        // "Standard BOL", "International Customs"
  documentType    String                        // "bol", "label", "customs", "daily_report"
  description     String?

  // Template content — HTML with Handlebars placeholders
  htmlTemplate    String

  // Configuration — JSON blob for type-specific settings
  config          Json?                         // e.g. { "pageSize": "letter", "orientation": "portrait" }

  // Metadata
  isDefault       Boolean  @default(false)      // One default per documentType
  active          Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documents       GeneratedDocument[]

  @@index([documentType])
  @@index([active])
}

model GeneratedDocument {
  id              String   @id @default(uuid())

  // What kind of document
  documentType    String                        // "bol", "label", "customs", "daily_report", "attachment"
  documentNumber  String?                       // Auto-generated BOL number, etc.
  fileName        String                        // "BOL-20260329-0001.pdf"
  mimeType        String   @default("application/pdf")
  fileSize        Int?                          // bytes

  // Storage — binary content (optional: new docs use external storage via storageKey)
  fileContent     Bytes?
  storageKey      String?                       // Opaque UUID-based key — no entity info or filenames
  storageBackend  String   @default("database") // "s3" or "database"

  // Template used (null for attachments/uploads)
  template        DocumentTemplate? @relation(fields: [templateId], references: [id])
  templateId      String?

  // Entity associations (polymorphic — at least one should be set)
  shipmentId      String?
  orderId         String?
  carrierId       String?
  customerId      String?

  // Who generated/uploaded it
  generatedBy     String?                       // userId

  // Metadata
  metadata        Json?                         // Snapshot of data used to generate
  notes           String?

  // Retention
  retentionExpiresAt DateTime?                  // Default: 10 years from creation. Null = indefinite.

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shipmentId])
  @@index([orderId])
  @@index([carrierId])
  @@index([customerId])
  @@index([documentType])
  @@index([createdAt])
  @@index([retentionExpiresAt])
}

// ─── Custom Fields (Versioned) ──────────────────────────────────────────────

model CustomFieldVersion {
  id          String   @id @default(uuid())
  entityType  String                        // "shipment", "order", "carrier", "customer", "location"
  version     Int                           // Auto-incremented per entityType
  description String?                       // E.g., "Added invoice number field"
  createdBy   String?                       // userId who created this version
  active      Boolean  @default(true)       // Only one active version per entityType

  createdAt   DateTime @default(now())

  fields      CustomFieldDefinition[]

  @@unique([entityType, version])
  @@index([entityType, active])
}

model CustomFieldDefinition {
  id          String   @id @default(uuid())
  version     CustomFieldVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId   String

  // Field identity
  fieldKey    String                        // Machine-readable key, e.g. "invoice_number" (stable across versions)
  label       String                        // Display label, e.g. "Invoice Number"
  description String?                       // Help text shown to users

  // Field type and configuration
  fieldType   String                        // "text", "decimal", "integer", "date", "boolean", "list", "multi_list"
  required    Boolean  @default(false)
  defaultValue String?                      // Stored as string, parsed by type

  // Type-specific configuration (JSON)
  config      Json?                         // {
                                            //   text: { minLength, maxLength, formatMask, pattern }
                                            //   decimal: { minValue, maxValue, decimalPlaces }
                                            //   integer: { minValue, maxValue }
                                            //   list/multi_list: { options: ["opt1","opt2",...] }
                                            //   date: { minDate, maxDate }
                                            // }

  // Display
  displayOrder Int     @default(0)          // Sort order in forms/views

  createdAt   DateTime @default(now())

  @@unique([versionId, fieldKey])
  @@index([versionId])
}

model CustomFieldAudit {
  id          String   @id @default(uuid())
  entityType  String
  action      String                        // "version_created", "field_added", "field_modified", "field_removed"
  versionId   String?                       // New version ID
  previousVersionId String?                 // Previous version ID
  changes     Json?                         // Details of what changed
  performedBy String?                       // userId
  createdAt   DateTime @default(now())

  @@index([entityType])
  @@index([createdAt])
}
