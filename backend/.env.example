# Database
DATABASE_URL=postgres://tms:tms@localhost:55432/tms

# Server
PORT=3001

# JWT
JWT_SECRET=open-tms-dev-secret-change-in-production

# Google Maps (optional, for distance calculations)
# GOOGLE_MAPS_API_KEY=your-api-key

# S3-Compatible File Storage (optional — falls back to database storage if not set)
# Works with: AWS S3, MinIO (local dev), Azure Blob (S3 compat mode), GCS
# For local dev with MinIO (docker-compose):
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=open-tms
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# For AWS S3:
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false

# For Azure Blob (S3 compat):
# S3_ENDPOINT=https://your-account.blob.core.windows.net
# S3_BUCKET=your-container
# S3_ACCESS_KEY_ID=your-storage-account
# S3_SECRET_ACCESS_KEY=your-storage-key
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=true
